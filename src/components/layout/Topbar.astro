---
import DatePicker from '../islands/DatePicker.svelte';

interface Props {
  title: string;
  user?: any;
  profileName?: string;
}

const { title, user, profileName = "User" } = Astro.props;
const selectedDate = Astro.url.searchParams.get('date');
---

<header class="h-[48px] flex-shrink-0 flex items-center justify-between px-10 border-b border-border-default bg-bg-base">
  <h2 class="text-[15px] font-medium text-text-primary">{title}</h2>
  
  <div class="flex items-center gap-4">
    <!-- Spacer for right alignment if needed -->
    <div></div>
  </div>
</header>
