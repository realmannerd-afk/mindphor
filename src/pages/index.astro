---
import RootLayout from "../layouts/RootLayout.astro";
import PublicNav from "../components/layout/PublicNav.astro";
import { getSupabaseClient } from '../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

if (userData?.user) {
  return Astro.redirect('/dashboard');
}
---

<RootLayout title="AI Reliability">
  <PublicNav />

  <!-- HERO SECTION -->
  <div
    class="w-full max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)] pt-[60px] pb-[120px]"
  >
    <div class="max-w-[580px]">
      <div
        class="text-[11px] uppercase tracking-[0.1em] text-text-muted mb-[24px] font-medium"
      >
        AI RELIABILITY — BUILT FOR PRODUCTION
      </div>

      <h1
        class="text-[clamp(28px,3.5vw,40px)] font-semibold text-text-primary leading-[1.15] mb-[20px] tracking-tight"
      >
        Know when your AI breaks.<br />Before your users do.
      </h1>

      <p
        class="text-[14px] text-text-secondary max-w-[480px] mb-[40px] leading-relaxed"
      >
        Mindphor tracks memory accuracy and eval scores for every AI call in
        production.
      </p>

      <div class="flex items-center gap-[12px]">
        <a
          href="/dashboard"
          class="bg-accent rounded-[8px] px-[20px] py-[10px] text-[14px] font-medium hover:bg-accent-hover hover:-translate-y-[2px] transition-all"
          style="color: var(--btn-text);"
        >
          Start Monitoring
        </a>
        <a
          href="/docs/quickstart"
          class="bg-transparent border border-border-strong text-text-primary rounded-[8px] px-[20px] py-[10px] text-[14px] font-medium hover:bg-bg-elevated hover:-translate-y-[2px] transition-all"
        >
          View the Docs
        </a>
      </div>
    </div>

    <!-- Hero Mac Mockup Window -->
    <div
      class="w-full mt-20 rounded-[12px] md:rounded-[16px] overflow-hidden border border-border-default shadow-md bg-bg-base flex flex-col"
    >
      <!-- Mac Window Header -->
      <div
        class="h-10 border-b border-border-faint flex items-center px-4 gap-2 bg-bg-surface/50 backdrop-blur-md"
      >
        <div class="w-3 h-3 rounded-full bg-[#FF5F56] border border-[#E0443E]">
        </div>
        <div class="w-3 h-3 rounded-full bg-[#FFBD2E] border border-[#DEA123]">
        </div>
        <div class="w-3 h-3 rounded-full bg-[#27C93F] border border-[#1AAB29]">
        </div>
      </div>
      <!-- Image Placeholder Container -->
      <div
        class="relative w-full aspect-[16/9] bg-bg-subtle flex flex-col items-center justify-center text-center p-6"
      >
        <svg
          class="w-8 h-8 text-text-muted mb-3"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        <span class="text-[14px] text-text-muted font-medium"
          >Add your real image inside this container</span
        >
        <span class="text-[12px] text-text-faint mt-1"
          >aspect-ratio: 16/9 recommended</span
        >
      </div>
    </div>
  </div>

  <!-- STATS BAR -->
  <div class="w-full bg-bg-subtle border-y border-border-default py-[32px]">
    <div class="max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)]">
      <div
        class="flex flex-wrap items-center justify-between gap-8 text-center"
      >
        <div class="flex-1">
          <div class="text-[28px] font-medium text-text-primary">12.4k</div>
          <div class="text-[12px] text-text-muted mt-[4px]">
            AI calls tracked today
          </div>
        </div>
        <div class="flex-1">
          <div class="text-[28px] font-medium text-text-primary">91%</div>
          <div class="text-[12px] text-text-muted mt-[4px]">
            avg memory accuracy
          </div>
        </div>
        <div class="flex-1">
          <div class="text-[28px] font-medium text-text-primary">84%</div>
          <div class="text-[12px] text-text-muted mt-[4px]">
            avg quality score
          </div>
        </div>
        <div class="flex-1">
          <div class="text-[28px] font-medium text-text-primary">&lt; 50ms</div>
          <div class="text-[12px] text-text-muted mt-[4px]">SDK overhead</div>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div
    class="w-full max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)] py-[96px]"
  >
    <div class="section-label">HOW IT WORKS</div>
    <h2 class="section-heading">Three steps to full AI visibility</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-16">
      <!-- Step 1 -->
      <div>
        <div class="text-[11px] text-text-faint font-mono mb-[12px]">01</div>
        <h3 class="text-[16px] font-medium text-text-primary mb-[6px]">
          Install the SDK
        </h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">
          Add @track to your LLM calls.<br />One decorator, full visibility.
        </p>
      </div>

      <!-- Step 2 -->
      <div>
        <div class="text-[11px] text-text-faint font-mono mb-[12px]">02</div>
        <h3 class="text-[16px] font-medium text-text-primary mb-[6px]">
          Memory + Eval tracking
        </h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">
          We capture context passed in,<br />score outputs automatically.
        </p>
      </div>

      <!-- Step 3 -->
      <div>
        <div class="text-[11px] text-text-faint font-mono mb-[12px]">03</div>
        <h3 class="text-[16px] font-medium text-text-primary mb-[6px]">
          Monitor in realtime
        </h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">
          Dashboard shows score trends,<br />memory drift, and alerts.
        </p>
      </div>
    </div>
  </div>
</RootLayout>
