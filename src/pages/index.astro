---
import RootLayout from "../layouts/RootLayout.astro";
import PublicNav from "../components/layout/PublicNav.astro";
import { getSupabaseClient } from '../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

if (userData?.user) {
  return Astro.redirect('/dashboard');
}
---

<RootLayout title="AI Reliability">
  <PublicNav />

  <!-- HERO SECTION -->
  <div
    class="w-full max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)] pt-[60px] pb-[120px]"
  >
    <div class="max-w-[580px]">
      <div
        class="text-[11px] uppercase tracking-[0.1em] text-text-muted mb-[24px] font-medium"
      >
        AI RELIABILITY — BUILT FOR PRODUCTION
      </div>

      <h1
        class="text-[clamp(28px,3.5vw,40px)] font-semibold text-text-primary leading-[1.15] mb-[20px] tracking-tight"
      >
        Know when your AI breaks.<br />Before your users do.
      </h1>

      <p
        class="text-[14px] text-text-secondary max-w-[480px] mb-[40px] leading-relaxed"
      >
        Mindphor tracks memory accuracy and eval scores for every AI call in
        production.
      </p>

      <div class="flex items-center gap-[12px]">
        <a
          href="/dashboard"
          class="bg-accent rounded-[8px] px-[20px] py-[10px] text-[14px] font-medium hover:bg-accent-hover transition-all"
          style="color: var(--btn-text);"
        >
          Start Monitoring
        </a>
        <a
          href="/docs/quickstart"
          class="bg-transparent border border-border-strong text-text-primary rounded-[8px] px-[20px] py-[10px] text-[14px] font-medium hover:bg-bg-elevated transition-all"
        >
          View the Docs
        </a>
      </div>
    </div>

    <!-- Hero Mac Mockup Window -->
    <div
      class="w-full mt-20 rounded-[12px] md:rounded-[16px] overflow-hidden border border-border-default bg-bg-base flex flex-col shadow-md"
    >
      <!-- Mac Window Header -->
      <div
        class="h-10 border-b border-border-faint flex items-center px-4 gap-2 bg-bg-surface/50 backdrop-blur-md"
      >
        <div class="w-3 h-3 rounded-full bg-[#FF5F56] border border-[#E0443E]">
        </div>
        <div class="w-3 h-3 rounded-full bg-[#FFBD2E] border border-[#DEA123]">
        </div>
        <div class="w-3 h-3 rounded-full bg-[#27C93F] border border-[#1AAB29]">
        </div>
      </div>
      <!-- Image Placeholder Container -->
      <div class="relative w-full aspect-[16/9] bg-bg-subtle overflow-hidden">
        <img 
          src="/light_screenshot.png" 
          alt="Mindphor Dashboard Analytics" 
          class="w-full h-full object-cover dark:hidden"
        />
        <img 
          src="/dark_screenshot.png" 
          alt="Mindphor Dashboard Analytics (Dark Mode)" 
          class="w-full h-full object-cover hidden dark:block"
        />
      </div>
    </div>
  </div>



  <!-- HOW IT WORKS -->
  <div
    id="how-it-works"
    class="w-full max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)] py-[96px]"
  >
    <div class="section-label">HOW IT WORKS</div>
    <h2 class="section-heading">Three steps to full AI visibility</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-16">
      <!-- Step 1 -->
      <div>
        <div class="text-[11px] text-text-faint font-mono mb-[12px]">01</div>
        <h3 class="text-[16px] font-medium text-text-primary mb-[6px]">
          Install the SDK
        </h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">
          Add @track to any function that calls an LLM. Two lines of code. Zero impact on performance. Works with OpenAI, Anthropic, or any AI provider.
        </p>
      </div>

      <!-- Step 2 -->
      <div>
        <div class="text-[11px] text-text-faint font-mono mb-[12px]">02</div>
        <h3 class="text-[16px] font-medium text-text-primary mb-[6px]">
          Every output gets scored
        </h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">
          A judge model evaluates each AI response in real time — scored 0 to 100. Flagged automatically when quality drops below your threshold.
        </p>
      </div>

      <!-- Step 3 -->
      <div>
        <div class="text-[11px] text-text-faint font-mono mb-[12px]">03</div>
        <h3 class="text-[16px] font-medium text-text-primary mb-[6px]">
          Know before your users do
        </h3>
        <p class="text-[13px] text-text-secondary leading-relaxed">
          See exactly which call failed, what your AI said, and why it was flagged. Real-time alerts when something goes wrong in production.
        </p>
      </div>
    </div>
  </div>

  <!-- WHY MINDPHOR -->
  <div id="why-mindphor" class="w-full bg-bg-subtle py-[96px]">
    <div class="max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)]">
      <div class="text-[11px] uppercase tracking-[0.06em] text-text-muted mb-[8px] font-medium">
        WHY MINDPHOR
      </div>
      <h2 class="text-[28px] font-medium text-text-primary mb-[48px] max-w-[520px] leading-[1.3]">
        Your database is correct.<br />Your AI might not know that.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Col 1 -->
        <div class="group">
          <div class="text-[11px] text-text-faint font-mono mb-[12px]">01</div>
          <h3 class="text-[16px] font-medium text-text-primary mb-[8px] group-hover:text-accent transition-colors duration-150 ease-in-out">
            Silent failures
          </h3>
          <p class="text-[13px] text-text-secondary leading-[1.7]">
            AI apps don't throw errors when they give wrong answers. Without monitoring you find out from angry users — days later.
          </p>
        </div>

        <!-- Col 2 -->
        <div class="group">
          <div class="text-[11px] text-text-faint font-mono mb-[12px]">02</div>
          <h3 class="text-[16px] font-medium text-text-primary mb-[8px] group-hover:text-accent transition-colors duration-150 ease-in-out">
            Prompt regressions
          </h3>
          <p class="text-[13px] text-text-secondary leading-[1.7]">
            Every time you update a prompt, quality can silently drop. Mindphor shows you exactly when it happened and by how much.
          </p>
        </div>

        <!-- Col 3 -->
        <div class="group">
          <div class="text-[11px] text-text-faint font-mono mb-[12px]">03</div>
          <h3 class="text-[16px] font-medium text-text-primary mb-[8px] group-hover:text-accent transition-colors duration-150 ease-in-out">
            Memory drift
          </h3>
          <p class="text-[13px] text-text-secondary leading-[1.7]">
            Your AI's context about a user can go stale or contradict itself. Mindphor detects this before it causes wrong answers in production.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA BANNER -->
  <div class="w-full py-[96px]">
    <div class="max-w-[520px] mx-auto px-6 text-center">
      <h2 class="text-[28px] font-medium text-text-primary mb-[12px] leading-tight">
        Start monitoring your AI today.
      </h2>
      <p class="text-[14px] text-text-secondary mb-[32px]">
        Free to start. No credit card required.
      </p>
      
      <div class="flex items-center justify-center gap-[12px]">
        <a
          href="/signup"
          class="bg-accent rounded-[8px] px-[20px] py-[10px] text-[14px] font-medium hover:bg-accent-hover transition-all"
          style="color: #FAFAF9;"
        >
          Start for free
        </a>
        <a
          href="/docs/quickstart"
          class="bg-transparent border border-border-strong text-text-primary rounded-[8px] px-[20px] py-[10px] text-[14px] font-medium hover:bg-bg-elevated transition-all"
        >
          View the Docs
        </a>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="w-full bg-bg-base border-t border-border-faint py-[48px]">
    <div class="max-w-[1100px] mx-auto px-[clamp(20px,5vw,80px)]">
      
      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-[40px]">
        <!-- Col 1 -->
        <div>
          <div class="text-[15px] font-medium text-text-primary mb-[8px]">
            Mindphor
          </div>
          <p class="text-[13px] text-text-muted max-w-[180px] leading-relaxed">
            AI reliability monitoring for production apps.
          </p>
        </div>

        <!-- Col 2 -->
        <div>
          <h4 class="text-[11px] uppercase tracking-[0.1em] text-text-faint mb-[16px] font-medium">PRODUCT</h4>
          <ul class="flex flex-col space-y-2">
            <li><a href="/#how-it-works" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">Overview</a></li>
            <li><a href="/#how-it-works" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">How it works</a></li>
            <li><a href="/docs/quickstart" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">Docs</a></li>
          </ul>
        </div>

        <!-- Col 3 -->
        <div>
          <h4 class="text-[11px] uppercase tracking-[0.1em] text-text-faint mb-[16px] font-medium">DEVELOPERS</h4>
          <ul class="flex flex-col space-y-2">
            <li><a href="/docs/quickstart" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">Quickstart</a></li>
            <li><a href="/docs/quickstart" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">SDK Install</a></li>
            <li><a href="https://github.com/realmannerd-afk/mindphor" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">GitHub</a></li>
          </ul>
        </div>

        <!-- Col 4 -->
        <div>
          <h4 class="text-[11px] uppercase tracking-[0.1em] text-text-faint mb-[16px] font-medium">ACCOUNT</h4>
          <ul class="flex flex-col space-y-2">
            <li><a href="/signup" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">Sign up</a></li>
            <li><a href="/login" class="text-[13px] text-text-muted hover:text-text-primary transition-colors duration-150 leading-[2.2]">Sign in</a></li>
          </ul>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="border-t border-border-faint pt-[24px] flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-[12px] text-text-faint">
          © 2026 Mindphor. All rights reserved.
        </div>
        <div class="flex items-center gap-4">
          <a href="https://github.com/realmannerd-afk/mindphor" class="text-text-muted hover:text-text-primary transition-colors duration-150" aria-label="GitHub">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
            </svg>
          </a>

        </div>
      </div>
      
    </div>
  </footer>
</RootLayout>
