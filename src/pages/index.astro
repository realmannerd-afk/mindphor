          <Highlighter client:only="react" action="underline" color="#3b82f6" strokeWidth={2}>
            <span class="text-text-primary">development</span>
          </Highlighter>.
          {" "}Access is{" "}
          <StraightHighlighter client:only="react">locked</StraightHighlighter>.
        </p>
      </div>
      <h1
