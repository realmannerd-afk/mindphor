---
import RootLayout from "../layouts/RootLayout.astro";
import PublicNav from "../components/layout/PublicNav.astro";
import { NumberTicker } from "../components/magicui/number-ticker";
import { getSupabaseClient } from '../lib/supabase';
import { IconAlertTriangle, IconTrendingUp, IconDevices, IconSearch, IconSparkles, IconBrain } from "@tabler/icons-svelte";

import FAQAccordionReact from "../components/islands/FAQAccordionReact.tsx";
import HowItWorksInteractive from "../components/islands/HowItWorksInteractive.svelte";
import FeatureShowcase from "../components/islands/FeatureShowcase.tsx";

import { Highlighter } from "../components/magicui/highlighter";
import { StraightHighlighter } from "../components/magicui/straight-highlighter";

const cookieHeader = Astro.request.headers.get('cookie') || '';
const hasSessionCookie = cookieHeader.includes('sb-');

let userData = null;
if (hasSessionCookie) {
  const supabase = getSupabaseClient(Astro.cookies);
  const { data } = await supabase.auth.getUser();
  userData = data;
}

if (userData?.user) {
  return Astro.redirect('/dashboard');
}
---

<RootLayout title="Customer Intel & Competitor Watch">
  <PublicNav />

  <div
    class="w-full max-w-[1400px] mx-auto px-[clamp(20px,5vw,80px)] pt-[116px] pb-[120px]"
  >
    <div class="max-w-[580px]">
      <div class="mb-8 w-full">
        <p class="text-[15px] font-medium text-text-secondary leading-relaxed">
