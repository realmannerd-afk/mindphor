---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { createClient } from '@supabase/supabase-js';

const { id } = Astro.params;

const mockTraces = [
  { id: 'tr_8f9a21', trace_id: 'tr_8f9a21', input: 'Extract JSON parameters from this invoice', output: '```json\n{\n  "amount": 120.50,\n  "date": "2023-10-12"\n}\n```', model: 'gpt-4o', status: 'active', score: 95, created_at: new Date().toISOString(), latency_ms: 1240, user_id: 'usr_abc123' },
  { id: 'tr_3b1c88', trace_id: 'tr_3b1c88', input: 'Write a python script to parse CSV files', output: 'import csv\n\nwith open("data.csv") as f:\n    reader = csv.reader(f)', model: 'claude-3.5-sonnet', status: 'active', score: 88, created_at: new Date().toISOString(), latency_ms: 850, user_id: 'usr_def456' },
  { id: 'tr_7d4e99', trace_id: 'tr_7d4e99', input: 'Summarize the latest product requirements', output: 'The new requirements emphasize faster load times and offline support.', model: 'gpt-4o', status: 'stale', score: 62, created_at: new Date().toISOString(), latency_ms: 2100, user_id: 'usr_ghi789' },
  { id: 'tr_1a2b3c', trace_id: 'tr_1a2b3c', input: 'Generate a SQL query for daily active users', output: 'SELECT date(created_at), count(distinct user_id) FROM events GROUP BY 1;', model: 'llama-3-70b', status: 'active', score: 45, created_at: new Date().toISOString(), latency_ms: 450, user_id: 'usr_jkl012' },
  { id: 'tr_9f8e7d', trace_id: 'tr_9f8e7d', input: 'Debug this React useEffect infinite loop', output: 'You are missing a dependency array in your useEffect hook.', model: 'gpt-4o', status: 'active', score: null, created_at: new Date().toISOString(), latency_ms: 1800, user_id: 'usr_mno345' },
];

let trace = mockTraces.find(t => t.id === id || t.trace_id === id);

if (!trace) {
  // Use Service Key to fetch the specific trace
  const supabaseUrl = import.meta.env.SUPABASE_URL;
  const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY;
  const supabase = createClient(supabaseUrl, supabaseKey);

  // Determine if id is a UUID to avoid Postgres type errors
  const isUuid = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id);
  
  const query = supabase.from('traces').select('*');
  if (isUuid) {
    query.eq('id', id);
  } else {
    query.eq('trace_id', id);
  }

  const { data, error } = await query.single();

  if (error || !data) {
    return Astro.redirect('/dashboard');
  }
  trace = data;
}

// Format the date
const date = new Date(trace.created_at).toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  hour12: true
});

function getScoreColor(score: number | null) {
  if (score === null) return 'text-text-muted bg-bg-elevated';
  if (score > 80) return 'text-[#2D5A0E] dark:text-emerald-400 bg-[#2D5A0E]/10 dark:bg-emerald-400/10 border-[#2D5A0E]/20 dark:border-emerald-400/20';
  if (score >= 60) return 'text-amber-600 dark:text-amber-400 bg-amber-600/10 dark:bg-amber-400/10 border-amber-600/20 dark:border-amber-400/20';
  return 'text-[#A32D2D] dark:text-red-400 bg-[#A32D2D]/10 dark:bg-red-400/10 border-[#A32D2D]/20 dark:border-red-400/20';
}

const scoreColor = getScoreColor(trace.score);
---

<DashboardLayout title="Traces">
  <div class="w-full">
    
    <!-- Back Navigation -->
    <a href="/dashboard" class="inline-flex items-center gap-2 text-[13px] font-medium text-text-muted hover:text-text-primary transition-colors mb-6 group">
      <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Back to traces
    </a>

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-6 mb-8">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-[28px] font-semibold text-text-primary tracking-tight">
            {trace.trace_id || trace.id}
          </h1>
          <span class={`px-3 py-1 text-[12px] font-medium rounded-full uppercase tracking-wider ${trace.status === 'active' ? 'bg-[var(--color-tag-fresh-bg)] text-[var(--color-tag-fresh-text)]' : 'bg-[var(--color-tag-stale-bg)] text-[var(--color-tag-stale-text)]'}`}>
            {trace.status}
          </span>
        </div>
        <p class="text-text-secondary text-[14px] flex items-center gap-3">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          {date}
        </p>
      </div>

      <!-- Quality Score Card -->
      <div class={`flex flex-col items-center justify-center px-8 py-4 rounded-[16px] border ${scoreColor}`}>
        <span class="text-[11px] uppercase tracking-wider font-semibold opacity-80 mb-1">Quality Score</span>
        <span class="text-[36px] font-bold tracking-tight leading-none">
          {trace.score !== null ? `${trace.score}%` : 'Pending'}
        </span>
      </div>
    </div>

    <!-- Metadata Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Model</span>
        <span class="text-[14px] text-text-primary font-medium">{trace.model || 'Unknown'}</span>
      </div>
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Latency</span>
        <span class="text-[14px] text-text-primary font-medium">{trace.latency_ms ? `${trace.latency_ms} ms` : 'N/A'}</span>
      </div>
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">User ID</span>
        <span class="text-[14px] text-text-primary font-mono truncate">{trace.user_id || 'Anonymous'}</span>
      </div>
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Trace ID</span>
        <span class="text-[14px] text-text-primary font-mono truncate">{trace.id}</span>
      </div>
    </div>

    <!-- Payload Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
      
      <!-- Input -->
      <div class="flex flex-col h-full">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-[14px] font-semibold text-text-primary uppercase tracking-wider">Input Prompt</h2>
          <button class="text-text-muted hover:text-text-primary transition-colors focus:outline-none" onclick="navigator.clipboard.writeText(document.getElementById('trace-input').innerText); window.showToast?.('Copied to clipboard', 'success');">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
        <div class="bg-[#1C1C1C] dark:bg-bg-surface border border-border-default rounded-[12px] p-5 flex-1 relative group overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent pointer-events-none"></div>
          <pre id="trace-input" class="text-[13px] text-[#E0E0E0] dark:text-text-secondary font-mono whitespace-pre-wrap leading-relaxed overflow-y-auto max-h-[500px]">{trace.input}</pre>
        </div>
      </div>

      <!-- Output -->
      <div class="flex flex-col h-full">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-[14px] font-semibold text-text-primary uppercase tracking-wider">AI Response</h2>
          <button class="text-text-muted hover:text-text-primary transition-colors focus:outline-none" onclick="navigator.clipboard.writeText(document.getElementById('trace-output').innerText); window.showToast?.('Copied to clipboard', 'success');">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          </button>
        </div>
        <div class="bg-[#1C1C1C] dark:bg-bg-surface border border-border-default rounded-[12px] p-5 flex-1 relative group overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent pointer-events-none"></div>
          <pre id="trace-output" class="text-[13px] text-[#E0E0E0] dark:text-text-secondary font-mono whitespace-pre-wrap leading-relaxed overflow-y-auto max-h-[500px]">{trace.output}</pre>
        </div>
      </div>

    </div>

  </div>
</DashboardLayout>
