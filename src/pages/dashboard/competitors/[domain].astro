  <!-- Real-time JavaScript Animations Engine -->
  <script is:inline>
    function initAnimations() {
      // 1. Number Counters
      const numElements = document.querySelectorAll('.animate-number');
      numElements.forEach(el => {
        const targetText = el.getAttribute('data-target') || '0';
        const isPercentage = targetText.includes('%');
        const isPlus = targetText.includes('+');
        const isMinus = targetText.includes('-');
        
        const rawMatch = targetText.match(/[0-9.]+/);
        if (!rawMatch) return;
        const target = parseFloat(rawMatch[0]);
        
        const duration = 1800; 
        const startTime = performance.now();
        
        function updateNum(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easeProgress = 1 - Math.pow(1 - progress, 4); 
          
          const current = target * easeProgress;
          let prefix = isPlus ? '+' : isMinus ? '-' : '';
          let suffix = isPercentage ? '%' : '';
          
          el.textContent = prefix + Math.floor(current) + suffix;
          
          if (progress < 1) {
            requestAnimationFrame(updateNum);
          } else {
            el.textContent = targetText; 
          }
        }
        requestAnimationFrame(updateNum);
      });

      // 2. Horizontal Progress Bars
      const bars = document.querySelectorAll('.animate-bar');
      setTimeout(() => {
        bars.forEach(bar => {
          const targetWidth = bar.getAttribute('data-width');
          if(targetWidth) bar.style.width = targetWidth;
        });
      }, 150);

      // 3. Conic Gradient Ring Animation
      const ring = document.querySelector('.animate-ring');
      if (ring) {
        const targetPerc = parseFloat(ring.getAttribute('data-perc') || '0');
        const duration = 1800;
        const startTime = performance.now();
        function updateRing(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easeProgress = 1 - Math.pow(1 - progress, 4);
          const currentPerc = targetPerc * easeProgress;
          
          ring.style.background = `conic-gradient(#818cf8 0% ${currentPerc}%, #e0e7ff ${currentPerc}% 100%)`;
          
          if (progress < 1) {
            requestAnimationFrame(updateRing);
          } else {
            ring.style.background = `conic-gradient(#818cf8 0% ${targetPerc}%, #e0e7ff ${targetPerc}% 100%)`;
          }
        }
        requestAnimationFrame(updateRing);
      }

      // 4. Functional Share Button Logic
      const shareBtn = document.getElementById('shareButton');
      if (shareBtn) {
        shareBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(window.location.href).then(() => {
            const span = shareBtn.querySelector('.share-text');
            const svg = shareBtn.querySelector('.share-icon');
            const originalText = span.textContent;
            const originalHtml = svg.innerHTML;
            
            span.textContent = 'Copied!';
            // Change to a checkmark
            svg.innerHTML = '<polyline points="20 6 9 17 4 12"></polyline>';
            svg.classList.add('text-[#10B981]');
            
            setTimeout(() => {
              span.textContent = originalText;
              svg.innerHTML = originalHtml;
              svg.classList.remove('text-[#10B981]');
            }, 2000);
          }).catch(err => {
            console.error('Failed to copy text: ', err);
          });
        });
      }

      // 5. Custom Dropdown Logic
      const dropdownBtn = document.getElementById('signalsDropdownBtn');
      const dropdownMenu = document.getElementById('signalsDropdownMenu');
      const dropdownContainer = document.getElementById('signalsDropdownContainer');
      const dropdownText = document.getElementById('signalsDropdownText');

      if (dropdownBtn && dropdownMenu) {
        dropdownBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          dropdownMenu.classList.toggle('hidden');
        });

        // Handle item clicks
        const items = dropdownMenu.querySelectorAll('button');
        items.forEach(item => {
          item.addEventListener('click', (e) => {
            e.stopPropagation();
            
            // Update active state visuals
            items.forEach(btn => {
              btn.classList.remove('text-text-primary', 'flex', 'items-center', 'justify-between');
              btn.classList.add('text-text-secondary');
              const svg = btn.querySelector('svg');
              if(svg) svg.remove();
            });
            
            item.classList.remove('text-text-secondary');
            item.classList.add('text-text-primary', 'flex', 'items-center', 'justify-between');
            item.innerHTML += ' <svg class="w-3 h-3 text-accent opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            
            // Update button text
            dropdownText.textContent = item.textContent.trim();
            dropdownMenu.classList.add('hidden');
          });
        });

        // Close on outside click
        document.addEventListener('click', (e) => {
          if (dropdownContainer && !dropdownContainer.contains(e.target)) {
            dropdownMenu.classList.add('hidden');
          }
        });
      }

      // 6. Add to Todo Logic
      document.querySelectorAll('.add-todo-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const task = btn.getAttribute('data-task');
          
          // Save to localStorage
          const saved = localStorage.getItem('mindphor_todos');
          const defaultTasks = [
            { id: '1', text: 'Review customer request overlap data', completed: false },
            { id: '2', text: 'Analyze latest pricing changes', completed: true },
          ];
          let tasks = saved ? JSON.parse(saved) : [...defaultTasks];
          if (!tasks.some(t => t.text === task)) {
            tasks.push({ id: Date.now().toString(), text: task, completed: false });
            localStorage.setItem('mindphor_todos', JSON.stringify(tasks));
          }

          // Show Minimal Toast Popup
          const popup = document.createElement('div');
          popup.innerHTML = `
            <div style="position:fixed; bottom:24px; right:24px; background:#18181B; color:#FFFFFF; padding:12px 16px; border-radius:8px; box-shadow:0 10px 15px -3px rgba(0,0,0,0.1); z-index:9999; display:flex; align-items:center; gap:10px; font-family:inherit; transform:translateY(100%); opacity:0; transition:all 0.3s cubic-bezier(0.16,1,0.3,1);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span style="font-size:14px; font-weight:500;">Added to Todo list</span>
            </div>
          `;
          document.body.appendChild(popup);
          
          // Animate in
          requestAnimationFrame(() => {
            popup.firstElementChild.style.opacity = '1';
            popup.firstElementChild.style.transform = 'translateY(0)';
          });
          
          // Redirect
          setTimeout(() => {
            window.location.href = '/dashboard/goals';
          }, 1200);
        });
      });
    }
    
    // Execute immediately and on view transitions
    initAnimations();
    document.addEventListener('astro:page-load', initAnimations);
  </script>
