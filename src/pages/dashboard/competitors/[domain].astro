---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseClient } from '../../../lib/supabase';
import Logo from '../../../components/islands/Logo.svelte';

const { domain } = Astro.params;
const competitorName = domain ? domain.split('.')[0].charAt(0).toUpperCase() + domain.split('.')[0].slice(1) : 'Competitor';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

let projectId = null;
if (userData?.user) {
  let { data: project } = await supabase.from('projects').select('id').eq('user_id', userData.user.id).limit(1);
  projectId = project?.[0]?.id;
} else {
  const isGuest = Astro.url.searchParams.get('guest') === 'true' || Astro.cookies.has('guest_mode');
  if (isGuest) {
    projectId = "guest_project";
  }
}

let competitorData = null;

if (projectId === 'guest_project') {
  const mockData = [
    { id: 'mk_1', user_id: 'Productivity', key: 'linear.app', value: 'Launched a new inline roadmap editor and custom workflow states today.', is_stale: false, updated_at: new Date().toISOString() },
  ];
  competitorData = mockData.find(k => k.key === domain);
} else if (projectId) {
  const { data } = await supabase
    .from('memory_keys')
    .select('*')
    .eq('project_id', projectId)
    .eq('key', domain)
    .single();
  if (data) competitorData = data;
}

if (!competitorData) {
  competitorData = { user_id: 'Productivity', key: domain, value: 'Monitoring active.', is_stale: false, updated_at: new Date().toISOString() };
}

const isActive = competitorData.is_stale === false || competitorData.status === 'fresh';
---

<DashboardLayout title="Competitor">
  
  <style>
    /* Real-time Layout Animations */
    .funnel-container {
      animation: expandFunnel 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      transform-origin: top;
      transform: scaleY(0);
    }
    @keyframes expandFunnel {
      100% { transform: scaleY(1); }
    }

    .animate-bar {
      width: 0%;
      transition: width 1.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .timeline-item {
      animation: slideLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
      transform: translateX(-15px);
    }
    @keyframes slideLeft {
      to { opacity: 1; transform: translateX(0); }
    }
    .timeline-item:nth-child(2) { animation-delay: 0.15s; }
    .timeline-item:nth-child(3) { animation-delay: 0.30s; }
    .timeline-item:nth-child(4) { animation-delay: 0.45s; }
    .timeline-item:nth-child(5) { animation-delay: 0.60s; }
    
    .timeline-item {
      animation: slideLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
