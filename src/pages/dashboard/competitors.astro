---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import MemoryViewer from '../../components/islands/MemoryViewer.svelte';
import { getSupabaseClient } from '../../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

let projectId = null;
if (userData?.user) {
  projectId = Astro.cookies.get('mindphor_app_id')?.value;
  
  let query = supabase.from('apps').select('id').eq('user_id', userData.user.id);
  if (projectId) {
    query = query.eq('id', projectId);
  } else {
    query = query.order('created_at', { ascending: false });
  }
  
  let { data: app } = await query.limit(1);
  projectId = app?.[0]?.id;
} else {
  return Astro.redirect('/login');
}

const selectedDate = Astro.url.searchParams.get('date') || '';
---

<DashboardLayout title="Competitors">
  <div class="w-full flex-1 flex flex-col">
    <MemoryViewer client:load projectId={projectId} date={selectedDate} />
  </div>
</DashboardLayout>
