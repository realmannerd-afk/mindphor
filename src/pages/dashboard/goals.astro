---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ActionTasks from '../../components/islands/ActionTasks.tsx';
import { getSupabaseClient } from '../../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

let appId = null;

if (userData?.user) {
  let activeId = Astro.cookies.get('mindphor_app_id')?.value;
  
  let query = supabase.from('apps').select('id').eq('user_id', userData.user.id);
  if (activeId) {
    query = query.eq('id', activeId);
  } else {
    query = query.order('created_at', { ascending: false });
  }
  
  let { data: apps } = await query.limit(1);
  if (apps && apps.length > 0) {
    appId = apps[0].id;
  }
} else {
      
}
let initialTasks: any[] = [];
if (appId ) {
  const { data: dbTasks } = await supabase
    .from('action_tasks')
    .select('*')
    .eq('app_id', appId)
    .order('order_index', { ascending: true });
    
  if (dbTasks) {
    initialTasks = dbTasks.map(t => ({
      id: t.id,
      text: t.text,
      checked: t.completed
    }));
  }
}
---

<DashboardLayout title="Goals & Action Plan">
  <div class="w-full flex-1 flex flex-col pt-0">
    <ActionTasks client:load appId={appId} initialTasks={initialTasks} />
  </div>
</DashboardLayout>
