---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getSupabaseClient } from '../../../lib/supabase';
import UserAvatar from '../../../components/islands/UserAvatar.svelte';
import Logo from '../../../components/islands/Logo.svelte';
import ReviewTranslator from '../../../components/islands/ReviewTranslator.svelte';

const { id } = Astro.params;

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

if (!userData?.user) {
  return Astro.redirect('/login');
}

// Fetch feedback entry
const { data: entry } = await supabase
  .from('feedback')
  .select('*, competitors(name, domain), apps(name)')
  .eq('id', id)
  .single();

if (!entry) {
  return Astro.redirect('/dashboard/feedback');
}

if (entry.score !== undefined && entry.score !== null) {
  if (entry.score < 3) entry.sentiment = 'critical';
  else if (entry.score === 3) entry.sentiment = 'neutral';
  else entry.sentiment = 'positive';
} else if (entry.sentiment === 'negative') {
  entry.sentiment = 'critical';
}

const sentimentColor = 
  entry.sentiment === 'positive' ? 'text-emerald-500' :
  entry.sentiment === 'critical' ? 'text-red-500' :
  'text-[#F59E0B]'; // Neutral / Other = Yellow

const sourceColor = 
  entry.source === 'Reddit' ? 'text-text-primary' :
  entry.source === 'App Store' ? 'text-text-primary' :
  (entry.source === 'Google Play' || entry.source === 'Play Store') ? 'text-text-primary' :
  'text-text-primary';

const targetName = entry.competitors?.name || entry.apps?.name || 'App';
let sourceLink = entry.url || '#';
if (!entry.url) {
  if (entry.source === 'Google Play') {
    sourceLink = `https://play.google.com/store/search?q=${encodeURIComponent(targetName)}&c=apps`;
  } else if (entry.source === 'App Store') {
    sourceLink = `https://apps.apple.com/us/search?term=${encodeURIComponent(targetName)}`;
  } else if (entry.source === 'Reddit') {
    sourceLink = `https://www.reddit.com/search/?q=${encodeURIComponent(targetName)}`;
  } else {
    sourceLink = `https://google.com/search?q=${encodeURIComponent(targetName + ' ' + entry.source)}`;
  }
}

const formatDate = (dateStr: string) => {
  if (!dateStr) return 'Unknown Date';
  return new Date(dateStr).toLocaleString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit'
  });
};

const authorName = entry.author || 'Anonymous User';
const plainTextContent = (entry.content || '').replace(/<[^>]*>?/gm, '');
const seoDescription = plainTextContent.length > 150 ? plainTextContent.substring(0, 147) + '...' : plainTextContent;

const contentLower = (entry.content || '').toLowerCase();
const tags = [];
if (contentLower.includes('crash') || contentLower.includes('bug') || contentLower.includes('fix') || contentLower.includes('error')) tags.push('Bug Report');
if (contentLower.includes('slow') || contentLower.includes('lag') || contentLower.includes('fast') || contentLower.includes('load')) tags.push('Performance');
if (contentLower.includes('ui') || contentLower.includes('design') || contentLower.includes('look') || contentLower.includes('button')) tags.push('UI/UX');
if (contentLower.includes('add') || contentLower.includes('feature') || contentLower.includes('wish') || contentLower.includes('want')) tags.push('Feature Request');
if (contentLower.includes('price') || contentLower.includes('subscription') || contentLower.includes('pay') || contentLower.includes('expensive')) tags.push('Pricing');
if (tags.length === 0) tags.push('General Feedback');
---

<DashboardLayout title="Feedback Details" description={seoDescription}>
  
  <div class="w-full flex flex-col pt-0 pb-6 pr-6 max-w-[1400px]">
    <!-- Top Nav / Header Toolbar -->
    <div class="flex items-center justify-between mb-6">
      <a href="/dashboard/feedback" class="text-[13px] font-medium text-text-primary hover:text-accent transition-colors flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to feedback
      </a>
    </div>

    <!-- Distinctive Header Area -->
    <div class="bg-bg-surface border border-border-default rounded-[16px] p-6 md:p-8 mb-6 relative overflow-hidden">
      
      <div class="relative z-10 flex flex-col gap-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class={`px-3 py-1.5 rounded-full text-[12px] font-bold tracking-wider uppercase flex items-center gap-1.5 whitespace-nowrap ${sourceColor}`}>
              <Logo client:load domain={(entry.source || '').replace('Play Store', 'play_store')} className="w-4 h-4 object-contain" />
              {entry.source}
            </div>
            
            <div class={`px-3 py-1.5 rounded-full text-[12px] font-bold tracking-wider uppercase flex items-center gap-1.5 ${sentimentColor}`}>
              {entry.sentiment === 'positive' && (
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19V5M5 12l7-7 7 7"></path></svg>
              )}
              {entry.sentiment === 'critical' && (
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 5v14M5 12l7 7 7-7"></path></svg>
              )}
              {entry.sentiment !== 'positive' && entry.sentiment !== 'critical' && (
                <span class="text-[14px] leading-none mt-[2px] font-bold">≈</span>
              )}
              {entry.sentiment}
            </div>

            <a href={sourceLink} target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-text-primary transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          </div>
          
          <div class="text-[13px] text-text-muted font-medium flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {formatDate(entry.date || entry.created_at)}
          </div>
        </div>

        <div class="w-full h-px bg-border-faint"></div>

        <!-- The actual feedback content with Native Translation -->
        <ReviewTranslator client:load content={entry.content || ''} />
        
        <!-- Profile Section -->
        <div class="flex items-center gap-3 mt-2 pt-6 border-t border-border-faint">
          <UserAvatar client:load name={authorName} />
          <div class="flex flex-col">
            <span class="text-[14px] font-semibold text-text-primary">{authorName}</span>
            <span class="text-[12px] text-text-muted">Feedback Submitter</span>
          </div>
        </div>
        
      </div>
    </div>

    <!-- Metadata & Analysis Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <!-- Key Topics & Tags Card -->
      <div class="bg-bg-surface border border-border-default rounded-[16px] p-6 flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-[12px] font-bold text-text-muted uppercase tracking-wider flex items-center gap-2">
            <svg class="w-4 h-4 text-text-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
            Key Topics & Tags
          </h3>
          <div class="text-[10px] font-bold uppercase tracking-widest text-text-primary flex items-center gap-1.5">
            <svg class="w-3 h-3 -mt-[2.5px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
            <span>AI Generated</span>
          </div>
        </div>
        
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <div class="px-3 py-1.5 rounded-lg bg-bg-subtle border border-border-default text-[13px] font-medium text-text-primary flex items-center gap-1.5">
              <div class="w-1.5 h-1.5 rounded-full bg-accent"></div>
              {tag}
            </div>
          ))}
        </div>
        
        <div class="mt-auto pt-6">
          <p class="text-[12px] text-text-muted leading-relaxed">
            These tags are automatically generated by AI analyzing the content of the user's feedback to help you quickly identify core issues.
          </p>
        </div>
      </div>

      <!-- Additional Details Card -->
      <div class="bg-bg-surface border border-border-default rounded-[16px] p-6 flex flex-col">
        <h3 class="text-[12px] font-bold text-text-muted uppercase tracking-wider mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 text-text-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Feedback Context
        </h3>
        
        <div class="flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <span class="text-[13px] text-text-secondary">Rating Score</span>
            <div class="flex items-center gap-1.5">
              {entry.score ? (
                <>
                  <svg class="w-4 h-4 text-[#F59E0B]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                  <span class="text-[13px] font-semibold text-text-primary">{entry.score} / 5</span>
                </>
              ) : (
                <span class="text-[13px] font-medium text-text-muted">No Rating</span>
              )}
            </div>
          </div>
          <div class="w-full h-px bg-border-faint"></div>
          <div class="flex items-center justify-between">
            <span class="text-[13px] text-text-secondary">App Version</span>
            <span class="text-[13px] font-medium text-text-primary">{entry.version || 'Unknown'}</span>
          </div>
          <div class="w-full h-px bg-border-faint"></div>
          <div class="flex items-center justify-between">
            <span class="text-[13px] text-text-secondary">Source Platform</span>
            <span class="text-[13px] font-medium text-text-primary">{entry.source || 'Direct'}</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</DashboardLayout>
