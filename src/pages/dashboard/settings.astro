---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import CompetitorsSetting from '../../components/islands/CompetitorsSetting.svelte';
import DeleteConfirmModal from '../../components/islands/DeleteConfirmModal.svelte';
import IntegrationsManager from '../../components/islands/IntegrationsManager.svelte';
import { getSupabaseClient } from '../../lib/supabase';
import { getUserPlanLimits } from '../../lib/planLimits';

let appName = 'Production App';
let userPlan = 'starter';

try {
  const supabase = getSupabaseClient(Astro.cookies);
  const { data: authData } = await supabase.auth.getUser();
  if (authData?.user) {
    const projectId = Astro.cookies.get('mindphor_app_id')?.value;
    
    let query = supabase.from('apps').select('id, name, alert_threshold, api_key, retention_days, memory_prune_limit, play_store_url, app_store_url, reddit_search_term, sync_frequency').eq('user_id', authData.user.id);
    if (projectId) {
      query = query.eq('id', projectId);
    } else {
      query = query.order('created_at', { ascending: false });
    }
    
    const { data: project } = await query.limit(1);
    if (project && project.length > 0) {
      const app = project[0];
      if (app.name) appName = app.name;
      // Expose these as globals for the client script
      Astro.locals.appId = app.id;
      Astro.locals.playStoreUrl = app.play_store_url || '';
      Astro.locals.appStoreUrl = app.app_store_url || '';
      Astro.locals.syncFrequency = app.sync_frequency || 'daily';
      Astro.locals.alertThreshold = app.alert_threshold || 5;
      Astro.locals.retentionDays = app.retention_days || 90;
      Astro.locals.memoryPruneLimit = app.memory_prune_limit || 1000;

      // Fetch competitor domains for this app
      const { data: competitorRows } = await supabase
        .from('competitors')
        .select('domain')
        .eq('app_id', app.id);
      Astro.locals.competitorDomains = (competitorRows || []).map((c: any) => c.domain).join(', ');
      Astro.locals.appId = app.id;
    }

    const planData = await getUserPlanLimits(Astro.cookies);
    userPlan = planData.plan;
  }
} catch (e) {
  console.error("Failed to fetch settings", e);
}
---

<DashboardLayout title="Settings">
  <div class="max-w-[1100px] w-full mx-auto md:mx-0">
    
    <div class="bg-bg-surface border border-border-default rounded-[16px] overflow-hidden flex flex-col divide-y divide-border-faint">
      
      <!-- Project Settings Group Header -->
      <div class="px-5 py-1.5 bg-bg-subtle">
        <div class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Workspace Configuration</div>
      </div>
      
      <!-- Row 1 -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group" data-setting-row="name">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Workspace Name</div>
          <div class="text-[13px] text-text-secondary">The display name for your Mindphor workspace</div>
        </div>
        <div class="flex items-center gap-2">
          <input type="text" value={appName} class="w-[260px] bg-transparent border border-transparent rounded-[6px] px-3 py-1.5 text-[13px] text-text-primary focus:outline-none text-left transition-colors data-[editing=true]:bg-bg-subtle data-[editing=true]:border-border-default data-[editing=true]:shadow-[inset_0_1px_2px_rgba(0,0,0,0.05)] data-[editing=true]:focus:border-border-strong" readonly data-setting-input />
          
          <button class="w-8 h-8 flex items-center justify-center rounded-md text-text-muted hover:text-text-primary hover:bg-bg-subtle transition-colors cursor-pointer" data-edit-btn>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" /><path d="M16 5l3 3" /></svg>
          </button>
          
          <button class="hidden px-3 py-1.5 bg-text-primary text-bg-base text-[12px] font-medium rounded-md hover:opacity-90 transition-opacity cursor-pointer" data-save-btn>
            Save
          </button>
        </div>
      </div>

      <!-- Sources & Tracking Group Header -->
      <div class="px-5 py-1.5 bg-bg-subtle border-t border-border-faint">
        <div class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Sources & Tracking</div>
      </div>
      
      <!-- Play Store URL -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group border-b border-border-faint" data-setting-row="play_store_url">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Play Store App ID</div>
          <div class="text-[13px] text-text-secondary">E.g., com.whatsapp (Used for pulling Android reviews)</div>
        </div>
        <div class="flex items-center gap-2">
          <input type="text" value={Astro.locals.playStoreUrl} placeholder="e.g. com.example.app" class="w-[260px] bg-transparent border border-transparent rounded-[6px] px-3 py-1.5 text-[13px] text-text-primary focus:outline-none text-left transition-colors data-[editing=true]:bg-bg-subtle data-[editing=true]:border-border-default data-[editing=true]:shadow-[inset_0_1px_2px_rgba(0,0,0,0.05)] data-[editing=true]:focus:border-border-strong" readonly data-setting-input />
          
          <button class="w-8 h-8 flex items-center justify-center rounded-md text-text-muted hover:text-text-primary hover:bg-bg-subtle transition-colors cursor-pointer" data-edit-btn>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" /><path d="M16 5l3 3" /></svg>
          </button>
          
          <button class="w-8 h-8 flex items-center justify-center rounded-md bg-text-primary text-bg-base hover:bg-text-secondary transition-colors hidden cursor-pointer" data-save-btn>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </button>
          
          <span class="text-[13px] text-green-500 font-medium hidden ml-2" data-success-msg>Saved</span>
        </div>
      </div>

      <!-- App Store URL -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group" data-setting-row="app_store_url">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Apple App Store URL</div>
          <div class="text-[13px] text-text-secondary">E.g., https://apps.apple.com/us/app/... (Used for iOS reviews)</div>
        </div>
        <div class="flex items-center gap-2">
          <input type="text" value={Astro.locals.appStoreUrl} placeholder="e.g. https://apps.apple.com/..." class="w-[260px] bg-transparent border border-transparent rounded-[6px] px-3 py-1.5 text-[13px] text-text-primary focus:outline-none text-left transition-colors data-[editing=true]:bg-bg-subtle data-[editing=true]:border-border-default data-[editing=true]:shadow-[inset_0_1px_2px_rgba(0,0,0,0.05)] data-[editing=true]:focus:border-border-strong" readonly data-setting-input />
          
          <button class="w-8 h-8 flex items-center justify-center rounded-md text-text-muted hover:text-text-primary hover:bg-bg-subtle transition-colors cursor-pointer" data-edit-btn>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" /><path d="M16 5l3 3" /></svg>
          </button>
          
          <button class="w-8 h-8 flex items-center justify-center rounded-md bg-text-primary text-bg-base hover:bg-text-secondary transition-colors hidden cursor-pointer" data-save-btn>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </button>
          
          <span class="text-[13px] text-green-500 font-medium hidden ml-2" data-success-msg>Saved</span>
        </div>
      </div>


      <!-- Competitor Domains -->
      <div class="px-6 py-4 flex items-start justify-between hover:bg-bg-subtle/50 transition-colors group">
        <div class="pt-1.5">
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Competitor App IDs</div>
          <div class="text-[13px] text-text-secondary">Comma-separated list of competitor Play Store App IDs to monitor</div>
        </div>
        <CompetitorsSetting client:load value={Astro.locals.competitorDomains || ''} appId={Astro.locals.appId} />
      </div>





      <!-- Auto-Sync Frequency -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group" data-setting-row="sync_frequency">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Auto-Sync Frequency</div>
          <div class="text-[13px] text-text-secondary">How often to automatically fetch new reviews and competitor data</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative">
            <select id="sync-frequency-select" class="w-[180px] bg-bg-surface border border-border-default rounded-[6px] pl-3 pr-8 py-1.5 text-[13px] text-text-primary focus:outline-none focus:border-border-strong appearance-none cursor-pointer transition-colors" data-sync-frequency-select>
              <option value="every_6_hours">Every 6 hours</option>
              <option value="daily">Daily (Default)</option>
              <option value="weekly">Weekly</option>
              <option value="manual">Manual Only</option>
            </select>
            <svg class="w-4 h-4 text-text-muted absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <span class="hidden text-green-500 text-[12px] font-medium ml-2" id="sync-freq-saved">Saved!</span>
          <span class="hidden text-red-500 text-[12px] font-medium ml-2" id="sync-freq-error">Error saving</span>
        </div>
      </div>





      <!-- Danger Zone Group Header -->
      <div class="px-5 py-1.5 bg-bg-subtle border-t border-border-faint">
        <div class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Danger Zone</div>
      </div>
      
      <!-- Row 5 -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Delete Project</div>
          <div class="text-[13px] text-text-secondary">Permanently delete this project and all traces. This cannot be undone.</div>
        </div>
        <button id="delete-project-btn" class="px-5 py-2 rounded-full border border-red-500/30 bg-red-500/10 text-red-600 text-[13px] font-medium hover:bg-red-500/20 transition-colors whitespace-nowrap cursor-pointer">
          Delete Project
        </button>
      </div>
    
    <DeleteConfirmModal client:load />
    </div>

    <!-- Integrations & API Section -->
    <div class="mt-12">
      <IntegrationsManager client:load plan={userPlan} />
    </div>

  </div>
  
  <script is:inline define:vars={{ 
    appId: Astro.locals.appId, 
    playStoreUrl: Astro.locals.playStoreUrl, 
    syncFrequency: Astro.locals.syncFrequency
  }}>
    window.__SYNC_APP_ID__ = appId;
    window.__SYNC_PLAY_STORE__ = playStoreUrl;
    // Hydrate the sync frequency dropdown with the value from the DB
    const sfSelect = document.getElementById('sync-frequency-select');
    if (sfSelect && syncFrequency) {
      sfSelect.value = syncFrequency;
    }
  </script>
</DashboardLayout>

<script>
  import { LogoService } from '../../lib/logos/LogoService';

  const initSettings = () => {
    const rows = document.querySelectorAll('[data-setting-row]');
    
    rows.forEach(row => {
      const input = row.querySelector('[data-setting-input]') as HTMLInputElement | HTMLSelectElement;
      const editBtn = row.querySelector('[data-edit-btn]') as HTMLButtonElement;
      const saveBtn = row.querySelector('[data-save-btn]') as HTMLButtonElement;
      
      if (!input || !editBtn || !saveBtn) return;
      
      editBtn.addEventListener('click', () => {
        input.removeAttribute('readonly');
        input.removeAttribute('disabled');
        input.setAttribute('data-editing', 'true');
        
        editBtn.classList.add('hidden');
        saveBtn.classList.remove('hidden');
        input.focus();
      });

      saveBtn.addEventListener('click', async () => {
        const rowId = row.getAttribute('data-setting-row');
        const successMsg = row.querySelector('[data-success-msg]') as HTMLSpanElement;
        
        const saveableFields = ['name', 'play_store_url', 'app_store_url', 'alert_threshold', 'retention_days', 'memory_prune_limit'];
        
        if (rowId && saveableFields.includes(rowId)) {
          let val: any = input.value;
          
          // Parse numbers for advanced settings
          if (['alert_threshold', 'retention_days', 'memory_prune_limit'].includes(rowId)) {
            val = parseInt(val, 10);
            if (isNaN(val)) return;
          }
          
          if (val !== undefined && val !== null) {
            if (typeof val === 'string') val = val.trim();
            
            try {
              const payload = { [rowId]: val };
              const res = await fetch('/api/settings', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
              if (res.ok) {
                // If we updated a sync URL, update the window variable too so the "Sync" button uses it without refresh
                if (rowId === 'play_store_url') window.__SYNC_PLAY_STORE__ = val;
                
                if (successMsg) {
                  successMsg.classList.remove('hidden');
                  setTimeout(() => successMsg.classList.add('hidden'), 2000);
                }
              }
            } catch (err) {
              console.error("Failed to save settings", err);
            }
          }
        }
        
        if (input.tagName === 'SELECT') {
          input.setAttribute('disabled', 'true');
        } else {
          input.setAttribute('readonly', 'true');
        }
        input.removeAttribute('data-editing');
        
        saveBtn.classList.add('hidden');
        editBtn.classList.remove('hidden');
      });
    });

    const deleteBtn = document.getElementById('delete-project-btn');
    if (deleteBtn) {
      deleteBtn.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-delete-modal', { detail: { appId: window.__SYNC_APP_ID__ } }));
      });
    }

    // ── Auto-Sync Frequency dropdown ──────────────────────────────────────
    const sfSelect = document.getElementById('sync-frequency-select') as HTMLSelectElement | null;
    const sfSaved = document.getElementById('sync-freq-saved') as HTMLSpanElement | null;
    const sfError = document.getElementById('sync-freq-error') as HTMLSpanElement | null;

    if (sfSelect) {
      sfSelect.addEventListener('change', async () => {
        const newFreq = sfSelect.value;
        sfSelect.disabled = true;
        try {
          const res = await fetch('/api/settings', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sync_frequency: newFreq })
          });
          if (res.ok) {
            sfSaved?.classList.remove('hidden');
            sfError?.classList.add('hidden');
            setTimeout(() => sfSaved?.classList.add('hidden'), 2000);
          } else {
            sfError?.classList.remove('hidden');
            sfSaved?.classList.add('hidden');
            setTimeout(() => sfError?.classList.add('hidden'), 3000);
          }
        } catch (err) {
          console.error('Failed to save sync_frequency', err);
          sfError?.classList.remove('hidden');
          sfSaved?.classList.add('hidden');
          setTimeout(() => sfError?.classList.add('hidden'), 3000);
        } finally {
          sfSelect.disabled = false;
        }
      });
    }
  };

  // Run init immediately (as module scripts are deferred) or on Astro page load if applicable
  initSettings();
</script>
