---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import CompetitorsSetting from '../../components/islands/CompetitorsSetting.svelte';
import { getSupabaseClient } from '../../lib/supabase';

let alertThreshold = 70;
let apiKey = '************************';
try {
  const supabase = getSupabaseClient(Astro.cookies);
  const { data: authData } = await supabase.auth.getUser();
  if (authData?.user) {
    const { data: project } = await supabase.from('apps').select('alert_threshold, api_key').eq('user_id', authData.user.id).limit(1);
    if (project && project.length > 0) {
      if (project[0].alert_threshold !== null) {
        alertThreshold = project[0].alert_threshold;
      }
      if (project[0].api_key) {
        apiKey = project[0].api_key;
      }
    }
  }
} catch (e) {
  console.error("Failed to fetch settings", e);
}
---

<DashboardLayout title="Settings">
  <div class="max-w-[800px]">
    
    <div class="bg-bg-surface border border-border-default rounded-[16px] overflow-hidden flex flex-col divide-y divide-border-faint">
      
      <!-- Project Settings Group Header -->
      <div class="px-5 py-1.5 bg-bg-subtle">
        <div class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Workspace Configuration</div>
      </div>
      
      <!-- Row 1 -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group" data-setting-row="name">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Workspace Name</div>
          <div class="text-[13px] text-text-secondary">The display name for your Mindphor workspace</div>
        </div>
        <div class="flex items-center gap-2">
          <input type="text" value="Production App" class="w-[260px] bg-transparent border border-transparent rounded-[6px] px-3 py-1.5 text-[13px] text-text-primary focus:outline-none text-left transition-colors data-[editing=true]:bg-bg-subtle data-[editing=true]:border-border-default data-[editing=true]:shadow-[inset_0_1px_2px_rgba(0,0,0,0.05)] data-[editing=true]:focus:border-border-strong" readonly data-setting-input />
          
          <button class="w-8 h-8 flex items-center justify-center rounded-md text-text-muted hover:text-text-primary hover:bg-bg-subtle transition-colors" data-edit-btn>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415" /><path d="M16 5l3 3" /></svg>
          </button>
          
          <button class="hidden px-3 py-1.5 bg-text-primary text-bg-base text-[12px] font-medium rounded-md hover:opacity-90 transition-opacity" data-save-btn>
            Save
          </button>
        </div>
      </div>

      <!-- Sources & Tracking Group Header -->
      <div class="px-5 py-1.5 bg-bg-subtle border-t border-border-faint">
        <div class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Sources & Tracking</div>
      </div>
      
      <!-- Competitor Domains -->
      <div class="px-6 py-4 flex items-start justify-between hover:bg-bg-subtle/50 transition-colors group">
        <div class="pt-1.5">
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Competitor Domains</div>
          <div class="text-[13px] text-text-secondary">Comma-separated list of competitor URLs to monitor</div>
        </div>
        <CompetitorsSetting client:load />
      </div>

      <!-- LLM Analysis Engine -->
      <div class="px-6 py-4 flex items-center justify-between hover:bg-bg-subtle/50 transition-colors group" data-setting-row="llm_model">
        <div>
          <div class="text-[14px] font-medium text-text-primary mb-0.5">Analysis Engine</div>
          <div class="text-[13px] text-text-secondary">LLM used for sentiment scoring and feedback categorization</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative">
