---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TraceTable from '../../components/islands/TraceTable.svelte';
import { getSupabaseClient } from '../../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

let projectId = null;
if (userData?.user) {
  projectId = Astro.cookies.get('mindphor_app_id')?.value;
  
  let query = supabase.from('apps').select('id').eq('user_id', userData.user.id);
  if (projectId) {
    query = query.eq('id', projectId);
  } else {
    query = query.order('created_at', { ascending: false });
  }
  
  let { data: apps } = await query.limit(1);
  projectId = apps?.[0]?.id;
} else {
   else {
    return Astro.redirect('/login');
  }
}

const selectedDate = Astro.url.searchParams.get('date') || '';
---

<DashboardLayout title="Feedback">
  <div class="absolute inset-0 px-10 pb-10 pt-6 flex flex-col min-h-0">
    <TraceTable client:load projectId={projectId} date={selectedDate} />
  </div>
</DashboardLayout>
