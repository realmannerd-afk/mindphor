---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseClient } from '../../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
let user = null;
let profileName = "User";

try {
  const { data } = await supabase.auth.getUser();
  user = data?.user;

  if (user) {
    const { data: profile } = await supabase.from('profiles').select('name').eq('id', user.id).single();
    if (profile?.name) {
      profileName = profile.name;
    } else if (user.user_metadata?.name) {
      profileName = user.user_metadata.name;
    }
  }
} catch (err) {
  console.error("Supabase profile error:", err);
}

const formattedDate = user?.created_at 
  ? new Date(user.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) 
  : "Recently";

const lastSignIn = user?.last_sign_in_at
  ? new Date(user.last_sign_in_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })
  : "Unknown";

const authProvider = user?.app_metadata?.provider 
  ? user.app_metadata.provider.charAt(0).toUpperCase() + user.app_metadata.provider.slice(1)
  : "Email";

const accountStatus = user?.email_confirmed_at ? "Verified" : "Unverified";
---

<DashboardLayout title="Profile Settings">
  <div class="max-w-3xl">
    <div class="mb-8">
      <h1 class="text-[24px] font-medium text-text-primary tracking-tight">Profile Settings</h1>
      <p class="text-[14px] text-text-secondary mt-1">Manage your account details and preferences.</p>
    </div>

    <div class="bg-bg-surface border border-border-default rounded-[16px] overflow-hidden mb-6">
      <!-- Card Header -->
      <div class="px-5 py-3 bg-bg-subtle border-b border-border-faint flex items-center gap-2">
        <span class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Profile Information</span>
      </div>

      <!-- Avatar Row -->
      <div class="flex items-center gap-5 px-6 py-5 border-b border-border-faint">
        <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 text-accent font-semibold text-[22px]">
          {profileName.charAt(0).toUpperCase()}
        </div>
        <div>
          <div class="text-[15px] font-medium text-text-primary">{profileName}</div>
          <div class="text-[13px] text-text-secondary mt-0.5">{user?.email}</div>
        </div>
      </div>

      <!-- Info Rows -->
      <div class="divide-y divide-border-faint">

        <!-- Full Name (editable) -->
        <div class="flex items-center justify-between px-6 py-4 hover:bg-bg-subtle/40 transition-colors" id="name-row">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
              <!-- Tabler: icon-pencil -->
              <svg class="w-[20px] h-[20px] text-text-muted" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4"/><path d="M13.5 6.5l4 4"/></svg>
            </div>
            <span class="text-[13px] text-text-secondary">Full Name</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- View mode -->
            <span id="name-display" class="text-[13px] font-medium text-text-primary">{profileName}</span>
            <!-- Edit mode (hidden by default) -->
            <input id="name-input" type="text" value={profileName} class="hidden w-[180px] bg-bg-subtle border border-border-default rounded-[6px] px-3 py-1.5 text-[13px] text-text-primary focus:outline-none focus:border-border-strong transition-colors" />
            <!-- Edit button -->
            <button id="name-edit-btn" class="w-8 h-8 flex items-center justify-center rounded-md text-text-muted hover:text-text-primary hover:bg-bg-subtle transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[16px] h-[16px]"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415"/><path d="M16 5l3 3"/></svg>
            </button>
            <!-- Save button (hidden by default) -->
            <button id="name-save-btn" class="hidden px-3 py-1.5 bg-text-primary text-bg-base text-[12px] font-medium rounded-md hover:opacity-90 transition-opacity">Save</button>
            <!-- Cancel button (hidden by default) -->
            <button id="name-cancel-btn" class="hidden px-3 py-1.5 text-[12px] font-medium text-text-secondary hover:text-text-primary transition-colors">Cancel</button>
            <!-- Saved feedback -->
            <span id="name-saved-msg" class="hidden text-[12px] font-medium text-green-500">Saved!</span>
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-center justify-between px-6 py-4 hover:bg-bg-subtle/40 transition-colors">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
              <!-- Tabler: icon-at -->
              <svg class="w-[20px] h-[20px] text-text-muted" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="12" cy="12" r="4"/><path d="M16 12v1.5a2.5 2.5 0 0 0 5 0v-1.5a9 9 0 1 0-5.7 8.4"/></svg>
            </div>
            <span class="text-[13px] text-text-secondary">Email Address</span>
          </div>
          <span class="text-[13px] font-medium text-text-primary">{user?.email}</span>
        </div>

      </div>
    </div>

    <!-- Account Details Card -->
    <div class="bg-bg-surface border border-border-default rounded-[16px] overflow-hidden mb-6">
      <!-- Card Header -->
      <div class="px-5 py-3 bg-bg-subtle border-b border-border-faint flex items-center gap-2">
        <span class="text-[10px] font-medium tracking-[0.1em] text-text-secondary uppercase">Account Details</span>
      </div>

      <!-- Stats Rows -->
      <div class="divide-y divide-border-faint">

        <!-- Account Status -->
        <div class="flex items-center justify-between px-6 py-4 hover:bg-bg-subtle/40 transition-colors">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
              <!-- Tabler: icon-shield-check -->
              <svg class="w-[20px] h-[20px] text-text-muted" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 -8.5 15a12 12 0 0 1 -8.5 -15a12 12 0 0 0 8.5 -3"/><path d="M9 12l2 2l4-4"/></svg>
            </div>
            <span class="text-[13px] text-text-secondary">Account Status</span>
          </div>
          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[12px] font-medium ${accountStatus === 'Verified' ? 'bg-green-500/10 text-green-600 border border-green-500/20' : 'bg-amber-400/10 text-amber-600 border border-amber-400/20'}`}>
            <span class={`w-1.5 h-1.5 rounded-full ${accountStatus === 'Verified' ? 'bg-green-500' : 'bg-amber-400'}`}></span>
            {accountStatus}
          </span>
        </div>

        <!-- Sign-in Method -->
        <div class="flex items-center justify-between px-6 py-4 hover:bg-bg-subtle/40 transition-colors">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
              <!-- Tabler: icon-key -->
              <svg class="w-[20px] h-[20px] text-text-muted" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="8" cy="15" r="4"/><line x1="10.85" y1="12.15" x2="19" y2="4"/><line x1="18" y1="5" x2="20" y2="7"/><line x1="15" y1="8" x2="17" y2="10"/></svg>
            </div>
            <span class="text-[13px] text-text-secondary">Sign-in Method</span>
          </div>
          <div class="flex items-center gap-2">
            {authProvider === 'Google' ? (
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            ) : (
              <svg class="w-4 h-4 text-text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            )}
            <span class="text-[13px] font-medium text-text-primary">{authProvider}</span>
          </div>
        </div>

        <!-- Member Since -->
        <div class="flex items-center justify-between px-6 py-4 hover:bg-bg-subtle/40 transition-colors">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
              <!-- Tabler: icon-calendar -->
              <svg class="w-[20px] h-[20px] text-text-muted" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><rect x="4" y="5" width="16" height="16" rx="2"/><line x1="16" y1="3" x2="16" y2="7"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="4" y1="11" x2="20" y2="11"/><line x1="11" y1="15" x2="12" y2="15"/><line x1="12" y1="15" x2="12" y2="18"/></svg>
            </div>
            <span class="text-[13px] text-text-secondary">Member Since</span>
          </div>
          <span class="text-[13px] font-medium text-text-primary">{formattedDate}</span>
        </div>

        <!-- Last Sign In -->
        <div class="flex items-center justify-between px-6 py-4 hover:bg-bg-subtle/40 transition-colors">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 flex items-center justify-center flex-shrink-0">
              <!-- Tabler: icon-clock -->
              <svg class="w-[20px] h-[20px] text-text-muted" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 15"/></svg>
            </div>
            <span class="text-[13px] text-text-secondary">Last Sign-in</span>
          </div>
          <span class="text-[13px] font-medium text-text-primary">{lastSignIn}</span>
        </div>

      </div>
    </div>


    <div class="bg-bg-surface border border-border-default rounded-[16px] p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h3 class="text-[14px] font-medium text-text-primary">Sign Out</h3>
        <p class="text-[13px] text-text-secondary mt-0.5">Log out of your account on this device securely.</p>
      </div>
      <a href="/api/auth/signout" class="h-[36px] px-5 flex items-center justify-center bg-bg-base border border-border-default text-text-primary text-[13px] font-medium rounded-full hover:bg-[#FEF2F2] hover:text-[#991B1B] hover:border-[#FCA5A5]:bg-[#450A0A]:text-[#FECACA]:border-[#7F1D1D] transition-colors whitespace-nowrap">
        Sign Out
      </a>
    </div>
  </div>
</DashboardLayout>

<script>
  const editBtn = document.getElementById('name-edit-btn');
  const saveBtn = document.getElementById('name-save-btn');
  const cancelBtn = document.getElementById('name-cancel-btn');
  const display = document.getElementById('name-display');
  const input = document.getElementById('name-input') as HTMLInputElement;
  const savedMsg = document.getElementById('name-saved-msg');

  let originalName = input?.value || '';

  editBtn?.addEventListener('click', () => {
    display?.classList.add('hidden');
    input?.classList.remove('hidden');
    editBtn?.classList.add('hidden');
    saveBtn?.classList.remove('hidden');
    cancelBtn?.classList.remove('hidden');
    input?.focus();
    input?.select();
  });

  cancelBtn?.addEventListener('click', () => {
    if (input) input.value = originalName;
    input?.classList.add('hidden');
    display?.classList.remove('hidden');
    saveBtn?.classList.add('hidden');
    cancelBtn?.classList.add('hidden');
    editBtn?.classList.remove('hidden');
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') saveBtn?.click();
    if (e.key === 'Escape') cancelBtn?.click();
  });

  saveBtn?.addEventListener('click', async () => {
    const newName = input?.value?.trim();
    if (!newName) return;
    saveBtn.textContent = 'Saving...';
    saveBtn.setAttribute('disabled', 'true');
    try {
      const res = await fetch('/api/settings', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: newName })
      });
      if (res.ok) {
        originalName = newName;
        if (display) display.textContent = newName;
        input?.classList.add('hidden');
        display?.classList.remove('hidden');
        saveBtn?.classList.add('hidden');
        cancelBtn?.classList.add('hidden');
        editBtn?.classList.remove('hidden');
        savedMsg?.classList.remove('hidden');
        setTimeout(() => savedMsg?.classList.add('hidden'), 2000);
      }
    } catch (err) {
      console.error('Failed to save name', err);
    } finally {
      saveBtn.textContent = 'Save';
      saveBtn.removeAttribute('disabled');
    }
  });
</script>
