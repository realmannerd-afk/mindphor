---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseClient } from '../../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
let user = null;
let profileName = "User";

try {
  const { data } = await supabase.auth.getUser();
  user = data?.user;

  if (user) {
    const { data: profile } = await supabase.from('profiles').select('name').eq('id', user.id).single();
    if (profile?.name) {
      profileName = profile.name;
    } else if (user.user_metadata?.name) {
      profileName = user.user_metadata.name;
    }
  }
} catch (err) {
  console.error("Supabase profile error:", err);
}

const formattedDate = user?.created_at 
  ? new Date(user.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) 
  : "Recently";
---

<DashboardLayout title="Profile Settings">
  <div class="max-w-3xl">
    <div class="mb-8">
      <h1 class="text-[24px] font-medium text-text-primary tracking-tight">Profile Settings</h1>
      <p class="text-[14px] text-text-secondary mt-1">Manage your account details and preferences.</p>
    </div>

    <div class="bg-bg-surface border border-border-default rounded-[16px] p-6 mb-6">
      <div class="flex items-center gap-5 mb-8 pb-8 border-b border-border-faint">
        <div class="w-20 h-20 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 text-accent font-medium text-[32px]">
          {profileName.charAt(0).toUpperCase()}
        </div>
        <div>
          <h2 class="text-[18px] font-medium text-text-primary">{profileName}</h2>
          <p class="text-[14px] text-text-secondary mt-0.5">{user?.email}</p>
        </div>
      </div>

      <div class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-[13px] font-medium text-text-primary mb-1.5">Full Name</label>
            <input type="text" value={profileName} readonly class="w-full bg-bg-base border border-border-default rounded-md px-3 py-2 text-[14px] text-text-primary focus:outline-none transition-colors opacity-70 cursor-not-allowed" />
            <p class="text-[12px] text-text-muted mt-2">Your name is synced securely from your profile.</p>
          </div>

          <div>
            <label class="block text-[13px] font-medium text-text-primary mb-1.5">Email Address</label>
            <input type="email" value={user?.email} readonly class="w-full bg-bg-base border border-border-default rounded-md px-3 py-2 text-[14px] text-text-primary focus:outline-none transition-colors opacity-70 cursor-not-allowed" />
          </div>
          
          <div>
            <label class="block text-[13px] font-medium text-text-primary mb-1.5">Account ID</label>
            <input type="text" value={user?.id} readonly class="w-full bg-bg-base border border-border-default rounded-md px-3 py-2 text-[14px] text-text-primary font-mono text-[12px] focus:outline-none transition-colors opacity-70 cursor-not-allowed" />
          </div>
          
          <div>
            <label class="block text-[13px] font-medium text-text-primary mb-1.5">Member Since</label>
            <input type="text" value={formattedDate} readonly class="w-full bg-bg-base border border-border-default rounded-md px-3 py-2 text-[14px] text-text-primary focus:outline-none transition-colors opacity-70 cursor-not-allowed" />
          </div>
        </div>
      </div>
    </div>

    <div class="bg-bg-surface border border-border-default rounded-[16px] p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h3 class="text-[14px] font-medium text-text-primary">Sign Out</h3>
        <p class="text-[13px] text-text-secondary mt-0.5">Log out of your account on this device securely.</p>
      </div>
      <a href="/api/auth/signout" class="h-[36px] px-5 flex items-center justify-center bg-bg-base border border-border-default text-text-primary text-[13px] font-medium rounded-md hover:bg-[#FEF2F2] hover:text-[#991B1B] hover:border-[#FCA5A5]:bg-[#450A0A]:text-[#FECACA]:border-[#7F1D1D] transition-colors whitespace-nowrap">
        Sign Out
      </a>
    </div>
  </div>
</DashboardLayout>
