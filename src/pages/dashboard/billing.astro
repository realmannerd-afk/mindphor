---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getSupabaseClient } from '../../lib/supabase';

const supabase = getSupabaseClient(Astro.cookies);
const { data: userData } = await supabase.auth.getUser();

if (!userData?.user) {
  return Astro.redirect('/login');
}

const paddleToken = import.meta.env.PUBLIC_PADDLE_CLIENT_TOKEN;
const starterPrice = import.meta.env.PUBLIC_PADDLE_STARTER_PRICE_ID;
const growthPrice = import.meta.env.PUBLIC_PADDLE_GROWTH_PRICE_ID;
const proPrice = import.meta.env.PUBLIC_PADDLE_PRO_PRICE_ID;

// Optional: fetch the user's current subscription status from the database
const { data: sub } = await supabase
  .from('subscriptions')
  .select('plan, status, current_period_end')
  .eq('user_id', userData.user.id)
  .maybeSingle();

const currentPlan = sub?.plan || null;
const isStarter = currentPlan === 'starter';
const isGrowth = currentPlan === 'growth';
const isPro = currentPlan === 'pro';
---

<DashboardLayout title="Billing & Plans">
  <div class="w-full max-w-[1000px] mx-auto py-8">
    <div class="mb-8">
      <h1 class="text-[clamp(18px,2vw,24px)] font-semibold text-text-primary leading-tight tracking-tight mb-2">Manage your subscription</h1>
      <p class="text-[13px] text-text-secondary">Upgrade your plan to track more apps, monitor competitors, and unlock real-time anomaly alerts.</p>
    </div>

    <!-- Current Subscription Details -->
    <!-- Current Subscription Details -->
    {sub && (
      <div class="mb-10 p-6 bg-bg-base border border-border-default rounded-[12px]">
        <h2 class="text-[15px] font-semibold text-text-primary mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"></path></svg>
          Current Subscription
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <div class="flex items-center gap-1.5 text-[11px] text-text-muted mb-1 uppercase tracking-wider font-mono font-medium">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
              Active Plan
            </div>
            <div class="text-[14px] font-medium text-text-primary capitalize">{sub.plan} Plan</div>
          </div>
          <div>
            <div class="flex items-center gap-1.5 text-[11px] text-text-muted mb-1 uppercase tracking-wider font-mono font-medium">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Status
            </div>
            <div class="text-[14px] font-medium text-text-primary capitalize flex items-center gap-2">
              <span class={`w-2 h-2 rounded-full ${sub.status === 'active' ? 'bg-[#10b981]' : (sub.status === 'canceled' ? 'bg-[#ef4444]' : 'bg-[#f59e0b]')}`}></span>
              {sub.status}
            </div>
          </div>
          <div>
            <div class="flex items-center gap-1.5 text-[11px] text-text-muted mb-1 uppercase tracking-wider font-mono font-medium">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              Billing Period Ends
            </div>
            <div class="text-[14px] font-medium text-text-primary">
              {sub.current_period_end ? new Date(sub.current_period_end).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A'}
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Pricing Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      
      <!-- Starter Card -->
      <div class="flex flex-col h-full bg-bg-base border border-border-default rounded-[12px] p-8 text-left transition-all hover:border-text-primary/20 relative">
        {isStarter && <div class="absolute -top-3 left-8 bg-text-primary text-bg-base text-[10px] uppercase tracking-wider font-semibold px-3 py-1 rounded-full">Current Plan</div>}
        <div class="text-[11px] uppercase tracking-wider text-text-muted font-mono font-semibold mb-2">Starter</div>
        <div class="flex items-end gap-1 mb-6">
          <span class="text-[32px] font-semibold text-text-primary leading-none">$0</span>
          <span class="text-[12px] text-text-muted mb-1">/mo</span>
        </div>
        <ul class="text-[13px] text-text-secondary space-y-3.5 mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-muted mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>1 Android App tracked</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-muted mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Up to 1,000 reviews/mo</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-muted mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>1 Competitor tracked</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-muted mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Basic sentiment metrics</span>
          </li>
        </ul>
        <button
          id="btn-starter"
          disabled={isStarter}
          class={`mt-auto block w-full border rounded-full py-3 text-[13px] font-medium transition-colors text-center ${isStarter ? 'bg-bg-subtle text-text-muted border-transparent cursor-not-allowed' : 'bg-transparent border-border-default text-text-primary hover:bg-bg-elevated'}`}
        >
          {isStarter ? 'Current Plan' : 'Downgrade to Starter'}
        </button>
      </div>

      <!-- Growth Card -->
      <div class="flex flex-col h-full bg-bg-base border border-accent/30 rounded-[12px] p-8 text-left relative">
        {isGrowth ? 
          <div class="absolute -top-3 left-8 bg-text-primary text-bg-base text-[10px] uppercase tracking-wider font-semibold px-3 py-1 rounded-full">Current Plan</div>
          : 
          <div class="absolute -top-3 left-8 bg-accent text-bg-base text-[10px] uppercase tracking-wider font-semibold px-3 py-1 rounded-full">Most Popular</div>
        }
        <div class="text-[11px] uppercase tracking-wider text-text-muted font-mono font-semibold mb-2">Growth</div>
        <div class="flex items-end gap-1 mb-6">
          <span class="text-[32px] font-semibold text-text-primary leading-none">$29</span>
          <span class="text-[12px] text-text-muted mb-1">/mo</span>
        </div>
        <ul class="text-[13px] text-text-secondary space-y-3.5 mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Up to 3 Android Apps tracked</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Unlimited review ingestion</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Up to 5 Competitors tracked</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Real-time anomaly alerts</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>AI-generated action plans</span>
          </li>
        </ul>
        <button
          id="btn-growth"
          disabled={isGrowth}
          class={`mt-auto block w-full rounded-full py-3 text-[13px] font-medium transition-colors text-center ${isGrowth ? 'bg-bg-subtle text-text-muted border border-transparent cursor-not-allowed' : 'bg-text-primary text-bg-base hover:opacity-90'}`}
        >
          {isGrowth ? 'Current Plan' : 'Upgrade to Growth'}
        </button>
      </div>

      <!-- Pro Card -->
      <div class="flex flex-col h-full bg-bg-base border border-border-default rounded-[12px] p-8 text-left transition-all hover:border-text-primary/20 relative">
        {isPro && <div class="absolute -top-3 left-8 bg-text-primary text-bg-base text-[10px] uppercase tracking-wider font-semibold px-3 py-1 rounded-full">Current Plan</div>}
        <div class="text-[11px] uppercase tracking-wider text-text-muted font-mono font-semibold mb-2">Pro</div>
        <div class="flex items-end gap-1 mb-6">
          <span class="text-[32px] font-semibold text-text-primary leading-none">$79</span>
          <span class="text-[12px] text-text-muted mb-1">/mo</span>
        </div>
        <ul class="text-[13px] text-text-secondary space-y-3.5 mb-8 flex-1">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Up to 10 Android Apps tracked</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Unlimited review ingestion</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Up to 15 Competitors tracked</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Priority email support</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-text-primary mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>API Access & Webhooks</span>
          </li>
        </ul>
        <button
          id="btn-pro"
          disabled={isPro}
          class={`mt-auto block w-full border rounded-full py-3 text-[13px] font-medium transition-colors text-center ${isPro ? 'bg-bg-subtle text-text-muted border-transparent cursor-not-allowed' : 'bg-transparent border-border-default text-text-primary hover:bg-bg-elevated'}`}
        >
          {isPro ? 'Current Plan' : 'Upgrade to Pro'}
        </button>
      </div>

    </div>
  </div>

  <script src="https://cdn.paddle.com/paddle/v2/paddle.js" is:inline></script>
  <script define:vars={{
    paddleToken,
    starterPrice,
    growthPrice,
    proPrice,
    userId: userData.user.id
  }}>
    Paddle.Environment.set('sandbox');
    Paddle.Initialize({ 
      token: paddleToken,
      eventCallback: function(data) {
        if (data.name === "checkout.completed") {
          // Refresh the page so the server fetches the newly updated subscription from Supabase
          setTimeout(() => window.location.reload(), 2000); 
        }
      }
    });

    // IMPORTANT: Inject customData so the webhook can link the payment to the user in the database
    const checkoutOptions = {
      customData: {
        supabase_user_id: userId
      }
    };

    document.getElementById('btn-starter')?.addEventListener('click', (e) => {
      e.preventDefault();
      if (starterPrice) {
        Paddle.Checkout.open({ items: [{ priceId: starterPrice, quantity: 1 }], ...checkoutOptions });
      } else {
        console.error("Missing Starter Price ID");
      }
    });

    document.getElementById('btn-growth')?.addEventListener('click', (e) => {
      e.preventDefault();
      if (growthPrice) {
        Paddle.Checkout.open({ items: [{ priceId: growthPrice, quantity: 1 }], ...checkoutOptions });
      } else {
        console.error("Missing Growth Price ID");
      }
    });

    document.getElementById('btn-pro')?.addEventListener('click', (e) => {
      e.preventDefault();
      if (proPrice) {
        Paddle.Checkout.open({ items: [{ priceId: proPrice, quantity: 1 }], ...checkoutOptions });
      } else {
        console.error("Missing Pro Price ID");
      }
    });
  </script>
</DashboardLayout>
