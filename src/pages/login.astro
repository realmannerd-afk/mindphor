---
import RootLayout from "../layouts/RootLayout.astro";
---

<RootLayout title="Sign In">
  <div
    class="relative min-h-[100dvh] flex flex-col items-center justify-center bg-bg-base p-6"
  >
    <a
      href="/"
      class="absolute top-4 left-4 md:top-4 md:left-6 flex items-center gap-2 text-[13px] font-medium text-text-secondary hover:text-text-primary transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
      >
      Back to home
    </a>
    <div class="w-full max-w-[400px]">
      <div class="text-center mb-8 flex flex-col items-center">
        <a href="/" class="group flex items-baseline gap-0 transition-opacity cursor-pointer mb-3">
          <span class="text-[20px] font-medium text-text-primary tracking-tight transition-opacity duration-200 group-hover:opacity-70">Mindphor</span>
        </a>
        <h1 class="text-xl font-medium text-text-primary mb-1">
          Welcome back
        </h1>
      </div>

      <div
        class="bg-bg-surface border border-border-default rounded-[16px] p-6"
      >
        <form class="space-y-4" id="login-form" onsubmit="event.preventDefault();">
          <div>
            <label
              class="block text-[13px] font-medium text-text-primary mb-1.5"
              for="email">Email address</label
            >
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="off"
              class="w-full bg-bg-base border border-border-default rounded-md px-3 py-2 text-[14px] text-text-primary focus:outline-none focus:border-border-strong focus:ring-1 focus:ring-border-strong transition-all shadow-sm"
              placeholder="name@company.com"
              required
            />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label
                class="block text-[13px] font-medium text-text-primary"
                for="password">Password</label
              >
              <a
                href="#"
                class="text-[12px] text-text-primary hover:text-accent font-medium transition-colors"
                >Forgot password?</a
              >
            </div>
            <div class="relative">
              <input
                type="password"
                id="password"
                name="password"
                autocomplete="new-password"
                class="w-full bg-bg-base border border-border-default rounded-md px-3 py-2 pr-10 text-[14px] text-text-primary focus:outline-none focus:border-border-strong focus:ring-1 focus:ring-border-strong transition-all shadow-sm"
                placeholder="••••••••"
                required
              />
              <button type="button" id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted hover:text-text-primary transition-colors focus:outline-none">
                <svg id="eye-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <svg id="eye-off-icon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                </svg>
              </button>
            </div>
          </div>

          <button
            id="login-submit"
            type="submit"
            class="w-full mt-6 h-[40px] flex items-center justify-center bg-accent text-white text-[14px] font-medium rounded-full hover:bg-accent-hover transition-colors shadow-sm"
          >
            Sign In
          </button>
        </form>

        <div class="mt-6 flex items-center gap-4">
          <div class="flex-1 h-[1px] bg-border-faint"></div>
          <span
            class="text-[12px] text-text-muted font-medium uppercase tracking-wider"
            >Or</span
          >
          <div class="flex-1 h-[1px] bg-border-faint"></div>
        </div>



        <button
          type="button"
          id="guest-login"
          class="w-full mt-3 h-[40px] flex items-center justify-center gap-2 bg-bg-surface border border-border-default text-text-primary text-[14px] font-medium rounded-full hover:bg-bg-subtle transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          Continue as Guest
        </button>
      </div>

      <p class="text-center mt-8 text-[14px] text-text-secondary">
        Don't have an account? <a
          href="/signup"
          class="text-text-primary font-medium hover:underline">Sign up</a
        >
      </p>
    </div>
  </div>
</RootLayout>

<script>
  const form = document.getElementById('login-form');
  const btn = document.getElementById('login-submit');
  const togglePassword = document.getElementById('toggle-password');
  const passwordInput = document.getElementById('password');
  const eyeIcon = document.getElementById('eye-icon');
  const eyeOffIcon = document.getElementById('eye-off-icon');

  togglePassword?.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    eyeIcon?.classList.toggle('hidden', isPassword);
    eyeOffIcon?.classList.toggle('hidden', !isPassword);
  });
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(btn) btn.innerHTML = 'Signing in...';
    
    const formData = new FormData(form);
    try {
      const res = await fetch('/api/auth/signin', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();
      
      if (!res.ok) {
        // @ts-ignore
        window.showToast(data.error || 'Failed to sign in', 'error');
        if(btn) btn.innerHTML = 'Sign In';
      } else {
        // @ts-ignore
        window.showToast('Successfully logged in!', 'success');
        setTimeout(() => {
          window.location.href = '/dashboard';
        }, 1500);
      }
    } catch (err) {
      // @ts-ignore
      window.showToast('Network error', 'error');
      if(btn) btn.innerHTML = 'Sign In';
    }
  });

  document.getElementById('guest-login')?.addEventListener('click', () => {
    document.cookie = "guest_mode=true; path=/; max-age=86400";
    window.location.href = '/dashboard';
  });
</script>
