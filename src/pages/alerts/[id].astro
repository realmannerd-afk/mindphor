---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { createClient } from '@supabase/supabase-js';
import AlertTimeline from '../../components/islands/AlertTimeline.tsx';
import RollingNumber from '../../components/islands/RollingNumber.svelte';

const { id } = Astro.params;

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

let alert: any = null;

const { data, error } = await supabase.from('alerts').select('*').eq('id', id).single();
if (error || !data) {
  return Astro.redirect('/dashboard/alerts');
}
alert = data;

if (!alert) throw new Error("Alert not found");

const messageText = alert.title || alert.description || "Anomaly Detected";
const scoreMatch = messageText.match(/scored (\d+)/);
const score = alert.score !== undefined ? alert.score : (scoreMatch ? parseInt(scoreMatch[1]) : null);

function formatAlertMessage(message: string) {
  if (!message) return "Anomaly Detected";
  
  // Keep only the core issue before the colon for a punchy title
  let formatted = message.split(':')[0].trim();
  
  // Remove robotic trailing words
  formatted = formatted.replace(/\bdetected\b/i, '').trim();
  
  // Ensure it looks like a clean title
  formatted = formatted.charAt(0).toUpperCase() + formatted.slice(1);
  
  return formatted || "System Anomaly";
}

const alertTypeStr = (alert.type || 'system').toLowerCase();
let category = "System Alert";
if (alertTypeStr.includes('critical')) category = 'Critical Anomaly';
else if (alertTypeStr.includes('error')) category = 'Error Spike';
else if (alertTypeStr.includes('warning')) category = 'Quality Warning';
else category = 'Insight';

let relativeTime = 'Just now';
if (alert.created_at) {
  const diffMins = Math.floor((new Date().getTime() - new Date(alert.created_at).getTime()) / 60000);
  const diffHours = Math.floor(diffMins / 60);
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays > 0) relativeTime = `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
  else if (diffHours > 0) relativeTime = `${diffHours} hr${diffHours > 1 ? 's' : ''} ago`;
  else if (diffMins > 0) relativeTime = `${diffMins} min${diffMins > 1 ? 's' : ''} ago`;
}

const dateStr = alert.created_at ? new Date(alert.created_at).toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  hour12: true
}) : relativeTime;

// Official Brand Icons
const iconApple = `<svg viewBox="0 0 384 512" class="w-4.5 h-4.5 text-text-primary" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>`;
const iconX = `<svg viewBox="0 0 512 512" class="w-3 h-3 text-text-primary" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L273.1 181.6 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>`;
const iconReddit = `<svg viewBox="0 0 512 512" class="w-4.5 h-4.5 text-[#FF4500]" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M201.5 305.5c-13.8 0-24.9-11.1-24.9-24.6 0-13.8 11.1-24.9 24.9-24.9 13.6 0 24.6 11.1 24.6 24.9 0 13.6-11.1 24.6-24.6 24.6zM504 256c0 137-111 248-248 248S8 393 8 256 119 8 256 8s248 111 248 248zm-132.3-41.2c-9.4 0-17.7 3.9-23.8 10-22.4-15.5-52.6-25.5-86.1-26.6l17.4-78.3 55.4 12.5c0 13.6 11.1 24.6 24.6 24.6 13.8 0 24.9-11.3 24.9-24.9s-11.1-24.9-24.9-24.9c-9.7 0-18 5.8-22.1 13.8l-61.2-13.6c-3-.8-6.1 1.4-6.9 4.4l-19.1 86.4c-33.2 1.4-63.1 11.3-85.5 26.8-6.1-6.4-14.7-10.2-24.1-10.2-34.9 0-46.3 46.9-14.4 62.8-1.1 5-1.7 10.2-1.7 15.5 0 52.6 59.2 95.2 132 95.2 73.1 0 132.3-42.6 132.3-95.2 0-5.3-.6-10.8-1.9-15.8 31.3-16 19.8-62.5-14.9-62.5zM302.8 331c-18.2 18.2-76.1 17.9-93.6 0-2.2-2.2-6.1-2.2-8.3 0-2.5 2.5-2.5 6.4 0 8.6 22.8 22.8 87.3 22.8 110.2 0 2.5-2.2 2.5-6.1 0-8.6-2.2-2.2-6.1-2.2-8.3 0zm7.7-75c-13.6 0-24.6 11.1-24.6 24.9 0 13.6 11.1 24.6 24.6 24.6 13.8 0 24.9-11.1 24.9-24.6 0-13.8-11-24.9-24.9-24.9z"/></svg>`;
const iconPlay = `<img src="https://upload.wikimedia.org/wikipedia/commons/d/d0/Google_Play_Arrow_logo.svg" alt="Google Play" class="w-4.5 h-4.5 object-contain" />`;

let alertSummary = alert.description || "System alert triggered based on monitored feedback metrics.";
let alertCategory = alert.type === 'error' ? "Error" : alert.type === 'warning' ? "Warning" : "Information";
let alertSeverity = alert.severity === 'critical' ? 'Critical' : (alert.severity === 'warning' ? 'Medium' : 'Low');
let alertStatus = alert.is_read ? "Reviewed" : "New";
let alertConfidence = alert.confidence || "96%";
const alertConfidenceInt = parseInt(alertConfidence) || 96;
const alertImpactInt = score !== null ? score : 55;

// Metrics block data
interface MetricItem {
  label: string;
  value: string;
  numValue?: number;
  valuePrefix?: string;
  valueSuffix?: string;
  sub: string;
  isDrop?: boolean;
  isWarning?: boolean;
  isConfidence?: boolean;
}

const metricsList: MetricItem[] = [];

let feedbackQuery: any = supabase
  .from('feedback')
  .select('source, content, created_at, score')
  .eq('app_id', alert.app_id)
  .order('created_at', { ascending: false })
  .limit(50);

const isNegativeAlert = alert.type === 'error' || alert.type === 'warning' || alert.severity === 'critical';
if (isNegativeAlert) {
  feedbackQuery = feedbackQuery.lte('score', 3);
}

// Extract specific keyword to filter evidence
const keywordMatch = messageText.match(/"([^"]+)"/);
if (keywordMatch && keywordMatch[1]) {
  feedbackQuery = feedbackQuery.ilike('content', `%${keywordMatch[1]}%`);
}

let feedbackData: any[] | null = null;
const { data: fbData } = await feedbackQuery;
feedbackData = fbData;

if (feedbackData && feedbackData.length > 0) {
  const totalScore = feedbackData.reduce((acc, f) => acc + (f.score || 0), 0);
  const avgScore = (totalScore / feedbackData.length).toFixed(1);
  const negativeCount = feedbackData.filter(f => (f.score || 0) <= 3).length;
  
  metricsList.push({ label: "Avg Rating (Affected)", value: avgScore, numValue: parseFloat(avgScore), isDrop: parseFloat(avgScore) < 4.0, sub: `Across ${feedbackData.length} recent reviews` });
  metricsList.push({ label: "Negative Sentiments", value: negativeCount.toString(), numValue: negativeCount, isWarning: negativeCount > 5, sub: "Score <= 3" });
  metricsList.push({ label: "Detected", value: relativeTime, sub: dateStr });
} else {
  metricsList.push({ label: "Alert Type", value: alert.type, sub: "Severity: " + alert.severity, isWarning: alert.severity === 'critical' });
  metricsList.push({ label: "Detected", value: relativeTime, sub: dateStr });
}

// Fetch readable app name
const { data: appData } = await supabase.from('apps').select('name').eq('id', alert.app_id).single();
const appName = appData?.name ? (appData.name.charAt(0).toUpperCase() + appData.name.slice(1) + ' Workspace') : 'Primary Workspace';
const displayAlertId = `AL-${alert.id.substring(0, 8).toUpperCase()}`;

// Fetch similar alerts from the database
const { data: similarAlertsData } = await supabase
  .from('alerts')
  .select('id, title, type, created_at')
  .eq('app_id', alert.app_id)
  .neq('id', alert.id)
  .order('created_at', { ascending: false })
  .limit(3);

if (feedbackData && feedbackData.length > 0 && isNegativeAlert) {
  const latestFeedback = feedbackData[0].content ? `"${feedbackData[0].content.substring(0, 60)}..."` : 'recent reviews';
  alertSummary = `Mindphor's intelligence engine identified an anomaly across ${feedbackData.length} recent data points for ${appName}. Users are actively reporting issues matching this alert (e.g., ${latestFeedback}). Immediate investigation into the latest release is recommended to prevent further negative sentiment.`;
}

// Evidence list
let evidenceList: Array<{ source: string; text: string; time: string; icon: string }> = [];
if (feedbackData && feedbackData.length > 0) {
  evidenceList = feedbackData.slice(0, 5).map(f => {
    let icon = `<svg class="w-4.5 h-4.5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
    const s = (f.source || '').toLowerCase();
    if (s.includes('play')) icon = iconPlay;
    if (s.includes('apple') || s.includes('app store')) icon = iconApple;
    if (s.includes('reddit')) icon = iconReddit;
    
    const date = new Date(f.created_at);
    const diffMins = Math.floor((new Date().getTime() - date.getTime()) / 60000);
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);
    
    let timeStr = 'just now';
    if (diffDays > 0) timeStr = `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
    else if (diffHours > 0) timeStr = `${diffHours} hr${diffHours > 1 ? 's' : ''} ago`;
    else if (diffMins > 0) timeStr = `${diffMins} min${diffMins > 1 ? 's' : ''} ago`;

    return {
      source: f.source || 'Unknown Source',
      text: (f.content || '').substring(0, 100) + '...',
      time: timeStr,
      icon: icon
    };
  });
} else {
  evidenceList = [
    { source: 'System Telemetry', text: `Unchecked warning trigger: "${messageText}"`, time: relativeTime, icon: `<svg class="w-4.5 h-4.5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>` }
  ];
}

// Sources affected
let sourcesList: Array<{ name: string; count: number; icon: string }> = [];
if (feedbackData && feedbackData.length > 0) {
  const sourceCounts = feedbackData.reduce((acc, row) => {
    const src = row.source || 'Unknown';
    acc[src] = (acc[src] || 0) + 1;
    return acc;
  }, {} as Record<string, number>);

  sourcesList = Object.entries(sourceCounts).map(([name, count]) => {
    let icon = `<svg class="w-4.5 h-4.5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`;
    const s = name.toLowerCase();
    if (s.includes('play')) icon = iconPlay;
    if (s.includes('apple') || s.includes('app store')) icon = iconApple;
    if (s.includes('reddit')) icon = iconReddit;

    return {
      name: name,
      count: count,
      icon: icon
    };
  });
} else {
  sourcesList = [
    { name: 'No Database Data Linked', count: 0, icon: `<svg class="w-4.5 h-4.5 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>` }
  ];
}

// Recommended actions
const actionsList: string[] = [
  "Review the raw evidence to understand the context of the issue.",
  "Check for recent changes or updates that correlate with this alert.",
  "Monitor incoming feedback closely to see if the trend continues."
];

---

<DashboardLayout title="Alerts">
  <div class="max-w-[1600px] mx-auto w-full">
    
    <!-- PAGE HEADER -->
    <div class="flex flex-col gap-6 mb-10 mt-2">
      <!-- Top nav row -->
      <div class="flex items-center justify-between">
        <a href="/dashboard/alerts" class="inline-flex items-center gap-1.5 text-[13px] font-medium text-text-muted hover:text-text-primary transition-colors outline-none w-max">
          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to alerts
        </a>
        <div class="text-[13px] font-medium text-text-muted">
          Jun 17, 2026, 12:33 PM
        </div>
      </div>
        
      <!-- Title & Badges -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <span class="px-2 py-1 bg-[#A32D2D]/10 text-[#A32D2D] rounded text-[11px] font-bold uppercase tracking-widest">{alertSeverity} Alert</span>
          <span class="text-[14px] text-text-secondary font-mono">#{displayAlertId}</span>
        </div>
        
        <h1 class="text-[28px] md:text-[32px] font-semibold tracking-tight text-text-primary max-w-4xl leading-[1.2]">
          {formatAlertMessage(messageText)}
        </h1>
        
        <div class="flex items-center gap-2 text-[14px] text-text-secondary font-medium">
          <span>{relativeTime}</span>
          <span>•</span>
          <span>{alertCategory}</span>
          <span>•</span>
          <span>{appName}</span>
        </div>
      </div>
    </div>

    <!-- MAIN LAYOUT (70 / 30 SPLIT) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
      
      <!-- LEFT COLUMN (Main Content - 70%) -->
      <div class="lg:col-span-8 flex flex-col gap-6">
        
        <!-- SECTION 1: AI Executive Summary -->
        <div class="bg-bg-surface border border-border-default rounded-[20px] p-8 flex flex-col gap-6">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>
            <h2 class="text-[16px] font-semibold text-text-primary">AI Summary</h2>
          </div>
          
          <div class="text-[14px] text-text-primary leading-relaxed max-w-4xl">
            <p>{alertSummary}</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-0 border border-border-faint rounded-xl overflow-hidden bg-bg-subtle/30 mt-2">
            {metricsList.map((m, idx) => (
              <div class={`p-5 flex flex-col h-full ${idx < 2 ? 'border-r border-border-faint' : ''}`}>
                <span class="text-[12px] text-text-secondary font-medium mb-3">{m.label}</span>
                <div class="flex items-center gap-2 min-h-[28px]">
                  <span class="text-[20px] font-semibold text-text-primary tabular-nums tracking-tight leading-none">
                    {m.numValue !== undefined ? (
                      <span class="inline-flex items-baseline gap-0.5">
                        {m.valuePrefix && <span class="text-[16px] text-text-muted">{m.valuePrefix}</span>}
                        <RollingNumber client:load value={m.numValue} />
                        {m.valueSuffix && <span class="text-[16px] text-text-muted">{m.valueSuffix}</span>}
                      </span>
                    ) : (
                      m.value
                    )}
                  </span>
                  {m.isDrop && (
                    <span class="inline-flex items-center justify-center w-5 h-5 rounded-md bg-[#A32D2D]/10 text-[#A32D2D]"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg></span>
                  )}
                  {m.isWarning && !m.isDrop && (
                    <span class="inline-flex items-center justify-center w-5 h-5 rounded-md bg-amber-500/10 text-amber-600"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg></span>
                  )}
                </div>
                <span class="text-[12px] text-text-muted mt-auto pt-3">{m.sub}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- SECTION 2 & 3: Evidence & Sources Combined -->
        <div class="bg-bg-surface border border-border-default rounded-[20px] flex flex-col overflow-hidden">
          <div class="p-6 pb-4 border-b border-border-faint">
            <h2 class="text-[14px] font-semibold text-text-primary">Evidence & Sources</h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-5 divide-y md:divide-y-0 md:divide-x divide-border-faint">
            
            <!-- Left: Evidence -->
            <div class="md:col-span-3 p-6 flex flex-col max-h-[360px] overflow-y-auto">
              <h3 class="text-[11px] font-semibold text-text-muted mb-5 uppercase tracking-wider">Raw Evidence ({evidenceList.length})</h3>
              <div class="flex flex-col">
                {evidenceList.map((ev) => (
                  <div class="flex items-start gap-3 py-3 border-b border-border-faint last:border-0 last:pb-0 first:pt-0">
                    <div class="mt-0.5 flex-shrink-0 opacity-60" set:html={ev.icon}></div>
                    <div class="flex flex-col w-full">
                      <p class="text-[13px] text-text-primary leading-relaxed">"{ev.text}"</p>
                      <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-[11px] font-medium text-text-muted">{ev.source}</span>
                        <span class="text-[10px] text-border-strong">•</span>
                        <span class="text-[11px] text-text-muted/80">{ev.time}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Right: Affected Sources -->
            <div class="md:col-span-2 p-6 flex flex-col max-h-[360px] overflow-y-auto">
              <h3 class="text-[11px] font-semibold text-text-muted mb-5 uppercase tracking-wider">Source Breakdown</h3>
              <div class="flex flex-col gap-5">
                {sourcesList.map(source => (
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <div class="flex-shrink-0" set:html={source.icon}></div>
                      <span class="text-[13px] font-medium text-text-primary">{source.name}</span>
                    </div>
                    <span class="text-[14px] font-medium text-text-primary tabular-nums">
                      {source.count !== undefined && <RollingNumber client:load value={source.count} />}
                    </span>
                  </div>
                ))}
              </div>
            </div>

          </div>
        </div>

        <!-- SECTION 4: Recommended Actions -->
        <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col mt-6">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-accent/10 text-accent flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
              </div>
              <h2 class="text-[15px] font-semibold text-text-primary">Recommended Actions</h2>
            </div>
            <span class={`px-2.5 py-1 rounded text-[11px] font-semibold tracking-wide ${alertSeverity === 'Critical' || alertSeverity === 'High' ? 'bg-[#A32D2D]/10 text-[#A32D2D]' : 'bg-amber-500/10 text-amber-600'}`}>Priority: {alertSeverity}</span>
          </div>

          <div class="flex flex-col gap-3">
            {actionsList.map((action, idx) => (
              <div class="action-item flex items-start gap-3 p-3.5 rounded-[12px] border border-border-faint bg-bg-base/50 hover:bg-bg-subtle transition-colors group cursor-pointer">
                <div class="action-icon mt-0.5 w-5 h-5 rounded-full bg-border-faint flex items-center justify-center text-[10px] font-bold text-text-secondary group-hover:bg-accent group-hover:text-white transition-colors" data-idx={idx + 1}>
                  {idx + 1}
                </div>
                <p class="action-text text-[13px] text-text-primary leading-relaxed flex-1 transition-all">{action}</p>
                <div class="action-arrow opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="w-4 h-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN (Sticky Sidebar - 30%) -->
      <div class="lg:col-span-4">
        <div class="sticky top-6 flex flex-col gap-6">
          
          <!-- Card 1: Alert Status -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col gap-5">
            <h2 class="text-[15px] font-semibold text-text-primary">Alert Status</h2>
            <div class="flex flex-col gap-4">
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Severity</span>
                <span class={`px-2 py-0.5 rounded text-[11px] font-bold ${alertSeverity === 'Critical' || alertSeverity === 'High' ? 'bg-[#A32D2D]/10 text-[#A32D2D]' : 'bg-amber-500/10 text-amber-600'}`}>{alertSeverity}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Status</span>
                <span class="px-2 py-0.5 bg-blue-500/10 text-blue-600 rounded text-[11px] font-bold">{alertStatus}</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Impact Score</span>
                <span class={`text-[14px] font-bold ${alertSeverity === 'Critical' || alertSeverity === 'High' ? 'text-[#A32D2D]' : 'text-amber-500'}`}><RollingNumber client:load value={alertImpactInt} />%</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Confidence</span>
                <span class="px-2 py-0.5 bg-emerald-500/10 text-emerald-600 rounded text-[11px] font-bold inline-flex items-baseline gap-0.5"><RollingNumber client:load value={alertConfidenceInt} />%</span>
              </div>
            </div>
          </div>

          <!-- Card 2: Alert Details -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col gap-5">
            <h2 class="text-[15px] font-semibold text-text-primary">Alert Details</h2>
            <div class="flex flex-col gap-3.5">
              <div class="flex justify-between items-start">
                <span class="text-[13px] text-text-secondary mt-0.5">Alert ID</span>
                <span class="text-[13px] text-text-primary font-mono">#{displayAlertId}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">Project</span>
                <span class="text-[13px] text-text-primary">{appName}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">Type</span>
                <span class="text-[13px] text-text-primary">{alertCategory}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">First Detected</span>
                <span class="text-[13px] text-text-primary">{dateStr}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">Last Updated</span>
                <span class="text-[13px] text-text-primary">{relativeTime}</span>
              </div>
            </div>
          </div>

          <!-- Card 3: Similar Alerts -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col gap-4">
            <h2 class="text-[15px] font-semibold text-text-primary">Similar Alerts</h2>
            <div class="flex flex-col gap-4 max-h-[250px] overflow-y-auto pr-2">
              {similarAlertsData && similarAlertsData.length > 0 ? (
                similarAlertsData.map(similar => {
                  const simDate = new Date(similar.created_at);
                  const diffDays = Math.floor((new Date().getTime() - simDate.getTime()) / (1000 * 3600 * 24));
                  const timeStr = diffDays > 0 ? `${diffDays} day${diffDays > 1 ? 's' : ''} ago` : 'Today';
                  const title = similar.title ? similar.title.split(':')[0].trim() : "Anomaly Detected";
                  const typeStr = similar.type ? similar.type.charAt(0).toUpperCase() + similar.type.slice(1) : 'Alert';
                  
                  return (
                    <div class="flex items-center justify-between outline-none">
                      <div class="flex flex-col gap-1 pr-3">
                        <span class="text-[13px] text-text-primary font-medium line-clamp-1">{title}</span>
                        <span class="text-[12px] text-text-muted">{typeStr} • {timeStr}</span>
                      </div>
                    </div>
                  )
                })
              ) : (
                <div class="text-[13px] text-text-muted italic py-4">No similar alerts detected.</div>
              )}
            </div>
          </div>

          <!-- Card 4: Actions -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-4 flex flex-col">
            <h2 class="text-[15px] font-semibold text-text-primary px-2 mb-2">Actions</h2>
            <div class="flex flex-col gap-0.5">
              <button id="btn-mute-alert" class="w-full px-2 py-2.5 flex items-center gap-3 hover:bg-bg-subtle rounded-md transition-colors text-left text-[13px] font-medium text-text-secondary hover:text-text-primary">
                <svg class="w-4.5 h-4.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg>
                Mute this alert
              </button>
              <button id="btn-share-alert" class="w-full px-2 py-2.5 flex items-center gap-3 hover:bg-bg-subtle rounded-md transition-colors text-left text-[13px] font-medium text-text-secondary hover:text-text-primary">
                <svg class="w-4.5 h-4.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                Share alert
              </button>
              <button id="btn-export-alert" class="w-full px-2 py-2.5 flex items-center gap-3 hover:bg-bg-subtle rounded-md transition-colors text-left text-[13px] font-medium text-text-secondary hover:text-text-primary">
                <svg class="w-4.5 h-4.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                Export report
              </button>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</DashboardLayout>

<script is:inline define:vars={{ alertId: alert.id, alertMessage: alert.message, appId: alert.app_id }}>
  document.addEventListener('DOMContentLoaded', () => {
    const muteBtn = document.getElementById('btn-mute-alert');
    const shareBtn = document.getElementById('btn-share-alert');
    const exportBtn = document.getElementById('btn-export-alert');

    if (muteBtn) {
      muteBtn.addEventListener('click', () => {
        muteBtn.innerHTML = `<svg class="w-4.5 h-4.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg> <span class="text-green-500">Muted Successfully</span>`;
        setTimeout(() => {
          muteBtn.innerHTML = `<svg class="w-4.5 h-4.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg> Mute this alert`;
        }, 2000);
      });
    }

    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        shareBtn.innerHTML = `<svg class="w-4.5 h-4.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg> <span class="text-green-500">Link Copied!</span>`;
        setTimeout(() => {
          shareBtn.innerHTML = `<svg class="w-4.5 h-4.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg> Share alert`;
        }, 2000);
      });
    }

    if (exportBtn) {
      exportBtn.addEventListener('click', () => {
        const payload = {
          id: alertId,
          message: alertMessage,
          exported_at: new Date().toISOString()
        };
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(payload, null, 2));
        const a = document.createElement('a');
        a.href = dataStr;
        a.download = `alert_${alertId}_export.json`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        
        exportBtn.innerHTML = `<svg class="w-4.5 h-4.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg> <span class="text-green-500">Downloaded!</span>`;
        setTimeout(() => {
          exportBtn.innerHTML = `<svg class="w-4.5 h-4.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg> Export report`;
        }, 2000);
      });
    }

    // Recommended Actions Checklist
    const actionItems = document.querySelectorAll('.action-item');
    actionItems.forEach(item => {
      item.addEventListener('click', () => {
        const isCompleted = item.classList.contains('completed');
        const iconDiv = item.querySelector('.action-icon');
        const textP = item.querySelector('.action-text');
        const arrowDiv = item.querySelector('.action-arrow');
        const originalIndex = iconDiv.getAttribute('data-idx');
        
        if (!isCompleted) {
          // Add to Action Plan (Goals page) via API
          fetch('/api/action_tasks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              app_id: appId,
              text: textP.innerText,
              completed: false,
              order_index: 999
            })
          }).catch(err => console.error("Failed to add task to goals:", err));

          item.classList.add('completed');
          item.classList.remove('bg-bg-base/50', 'hover:bg-bg-subtle', 'border-border-faint');
          item.classList.add('bg-emerald-500/10', 'border-emerald-500/20');
          iconDiv.innerHTML = `<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`;
          iconDiv.className = "action-icon mt-0.5 w-5 h-5 rounded-full bg-emerald-500 text-white flex items-center justify-center transition-colors";
          textP.classList.add('line-through', 'opacity-60');
          arrowDiv.classList.add('hidden');
        } else {
          item.classList.remove('completed');
          item.classList.remove('bg-emerald-500/10', 'border-emerald-500/20');
          item.classList.add('bg-bg-base/50', 'hover:bg-bg-subtle', 'border-border-faint');
          iconDiv.innerHTML = originalIndex;
          iconDiv.className = "action-icon mt-0.5 w-5 h-5 rounded-full bg-border-faint flex items-center justify-center text-[10px] font-bold text-text-secondary group-hover:bg-accent group-hover:text-white transition-colors";
          textP.classList.remove('line-through', 'opacity-60');
          arrowDiv.classList.remove('hidden');
        }
      });
    });
  });
</script>
