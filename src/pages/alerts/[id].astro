---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { createClient } from '@supabase/supabase-js';

const { id } = Astro.params;

const mockAlerts = [
  { id: 'al_1', type: 'error', message: 'Trace tr_124 scored 45 (below threshold 70).', sub: '10 mins ago • Quality Drop', created_at: new Date().toISOString(), project_id: 'guest_project' },
  { id: 'al_2', type: 'warning', message: 'Memory key "api_keys" has not been updated in 3 days.', sub: '1 hour ago • Stale Memory', created_at: new Date().toISOString(), project_id: 'guest_project' },
  { id: 'al_3', type: 'error', message: 'Conflicting values set for "user_preferences".', sub: '2 hours ago • Contradiction', created_at: new Date().toISOString(), project_id: 'guest_project' },
  { id: 'al_4', type: 'info', message: 'API latency spiked to 4.5s for trace tr_122.', sub: '5 hours ago • Performance', created_at: new Date().toISOString(), project_id: 'guest_project' },
];

let alert = mockAlerts.find(a => a.id === id);

if (!alert) {
  const supabaseUrl = import.meta.env.SUPABASE_URL;
  const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY;
  const supabase = createClient(supabaseUrl, supabaseKey);

  const { data, error } = await supabase
    .from('alerts')
    .select('*')
    .eq('id', id)
    .single();

  if (error || !data) {
    return Astro.redirect('/dashboard/alerts');
  }
  alert = data;
}

function getIcon(type: string) {
  if (type === 'error') return '<svg class="w-8 h-8 text-[#A32D2D] dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" /><path d="M12 8l0 4" /><path d="M12 16l.01 0" /></svg>';
  if (type === 'warning') return '<svg class="w-8 h-8 text-[#854F0B] dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v2m0 4v.01" /><path d="M5 19h14a2 2 0 0 0 1.84 -2.75l-7.1 -12.25a2 2 0 0 0 -3.5 0l-7.1 12.25a2 2 0 0 0 1.75 2.75" /></svg>';
  return '<svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" /><path d="M12 9h.01" /><path d="M11 12h1v4h1" /></svg>';
}

const date = alert.created_at ? new Date(alert.created_at).toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  hour12: true
}) : alert.sub; // Fallback to sub if created_at is missing (for mock data)

const scoreMatch = alert.message.match(/scored (\d+)/);
const score = scoreMatch ? parseInt(scoreMatch[1]) : null;

function getScoreColor(score: number | null) {
  if (score === null) return 'text-text-muted bg-bg-elevated border-border-default';
  if (score > 80) return 'text-[#2D5A0E] dark:text-emerald-400 bg-[#2D5A0E]/10 dark:bg-emerald-400/10 border-[#2D5A0E]/20 dark:border-emerald-400/20';
  if (score >= 60) return 'text-amber-600 dark:text-amber-400 bg-amber-600/10 dark:bg-amber-400/10 border-amber-600/20 dark:border-amber-400/20';
  return 'text-[#A32D2D] dark:text-red-400 bg-[#A32D2D]/10 dark:bg-red-400/10 border-[#A32D2D]/20 dark:border-red-400/20';
}

const scoreColor = getScoreColor(score);

function formatAlertMessage(message: string) {
  let formatted = message.replace(/(Trace [a-zA-Z0-9_-]+) scored \d+\s*—\s*/, '$1 - ');
  formatted = formatted.replace(/(Trace [a-zA-Z0-9_-]+) scored \d+ \((.*?)\)\.?/, '$1 - $2');
  return formatted;
}
---

<DashboardLayout title="Alerts">
  <div class="w-full">
    
    <a href="/dashboard/alerts" class="inline-flex items-center gap-2 text-[13px] font-medium text-text-muted hover:text-text-primary transition-colors mb-6 group">
      <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Back to alerts
    </a>

    <div class="flex flex-col md:flex-row md:items-stretch justify-between gap-6 mb-8">
      <div class="bg-bg-surface border border-border-default rounded-[16px] overflow-hidden p-8 flex items-start gap-6 flex-1">
        <div class="flex-shrink-0 mt-1">
          <Fragment set:html={getIcon(alert.type)} />
        </div>

        <div class="flex flex-col gap-3">
          <h1 class="text-[24px] font-semibold text-text-primary tracking-tight leading-snug">
            {formatAlertMessage(alert.message)}
          </h1>
          <p class="text-text-secondary text-[15px] flex items-center gap-3">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            {date}
          </p>
        </div>
      </div>
      
      {score !== null && (
        <div class={`flex flex-col items-center justify-center px-8 py-4 rounded-[16px] border ${scoreColor}`}>
          <span class="text-[11px] uppercase tracking-wider font-semibold opacity-80 mb-1 whitespace-nowrap">Alert Score</span>
          <span class="text-[36px] font-bold tracking-tight leading-none">
            {score}%
          </span>
        </div>
      )}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Severity Type</span>
        <span class="text-[14px] text-text-primary font-medium capitalize">{alert.type}</span>
      </div>
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Context</span>
        <span class="text-[14px] text-text-primary font-medium truncate">{alert.sub || 'System Event'}</span>
      </div>
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Internal ID</span>
        <span class="text-[14px] text-text-primary font-mono truncate">{alert.id}</span>
      </div>
      <div class="bg-bg-surface border border-border-default rounded-[12px] p-4 flex flex-col">
        <span class="text-[11px] text-text-muted uppercase tracking-wider font-semibold mb-1">Project ID</span>
        <span class="text-[14px] text-text-primary font-mono truncate">{alert.project_id || 'Global'}</span>
      </div>
    </div>

  </div>
</DashboardLayout>
