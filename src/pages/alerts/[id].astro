---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { createClient } from '@supabase/supabase-js';
import AlertTimeline from '../../components/islands/AlertTimeline.tsx';
import RollingNumber from '../../components/islands/RollingNumber.svelte';

const { id } = Astro.params;

let alert;
if (id === 'AL_124' || id?.toLowerCase() === 'al_124') {
  alert = {
    id: 'AL_124',
    type: 'critical',
    message: 'Login Failure Spike After Android Release 2.3.1',
    sub: '10 minutes ago • Quality Drop',
    created_at: new Date().toISOString(),
    project_id: 'Mobile App',
    confidence: '96%',
    score: 45
  };
} else {
  // Mock fallback or real DB
  const mockAlerts = [
    { id: 'al_1', type: 'error', message: 'Trace tr_124 scored 45 (below threshold 70).', sub: '10 mins ago • Quality Drop', created_at: new Date().toISOString(), project_id: 'guest_project', score: 45 },
    { id: 'al_2', type: 'warning', message: 'Memory key "api_keys" has not been updated in 3 days.', sub: '1 hour ago • Stale Memory', created_at: new Date().toISOString(), project_id: 'guest_project', score: null },
  ];
  alert = mockAlerts.find(a => a.id === id);
  if (!alert) {
    const supabaseUrl = import.meta.env.SUPABASE_URL;
    const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY;
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data, error } = await supabase.from('alerts').select('*').eq('id', id).single();
    if (error || !data) {
      return Astro.redirect('/dashboard/alerts');
    }
    alert = data;
  }
}

if (!alert) throw new Error("Alert not found");

// Force fallback so formatting logic won't fail if we don't have a score explicitly on the object
const scoreMatch = alert.message.match(/scored (\d+)/);
const score = alert.score !== undefined ? alert.score : (scoreMatch ? parseInt(scoreMatch[1]) : null);

function formatAlertMessage(message: string) {
  let formatted = message.replace(/(Trace [a-zA-Z0-9_-]+) scored \d+\s*—\s*/, '$1 - ');
  formatted = formatted.replace(/(Trace [a-zA-Z0-9_-]+) scored \d+ \((.*?)\)\.?/, '$1 - $2');
  return formatted;
}

const dateStr = alert.created_at ? new Date(alert.created_at).toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  hour12: true
}) : alert.sub;

// Official Brand Icons
const iconApple = `<svg viewBox="0 0 384 512" class="w-4.5 h-4.5 text-text-primary" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>`;
const iconX = `<svg viewBox="0 0 512 512" class="w-3 h-3 text-text-primary" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L273.1 181.6 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>`;
const iconReddit = `<svg viewBox="0 0 512 512" class="w-4.5 h-4.5 text-[#FF4500]" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M201.5 305.5c-13.8 0-24.9-11.1-24.9-24.6 0-13.8 11.1-24.9 24.9-24.9 13.6 0 24.6 11.1 24.6 24.9 0 13.6-11.1 24.6-24.6 24.6zM504 256c0 137-111 248-248 248S8 393 8 256 119 8 256 8s248 111 248 248zm-132.3-41.2c-9.4 0-17.7 3.9-23.8 10-22.4-15.5-52.6-25.5-86.1-26.6l17.4-78.3 55.4 12.5c0 13.6 11.1 24.6 24.6 24.6 13.8 0 24.9-11.3 24.9-24.9s-11.1-24.9-24.9-24.9c-9.7 0-18 5.8-22.1 13.8l-61.2-13.6c-3-.8-6.1 1.4-6.9 4.4l-19.1 86.4c-33.2 1.4-63.1 11.3-85.5 26.8-6.1-6.4-14.7-10.2-24.1-10.2-34.9 0-46.3 46.9-14.4 62.8-1.1 5-1.7 10.2-1.7 15.5 0 52.6 59.2 95.2 132 95.2 73.1 0 132.3-42.6 132.3-95.2 0-5.3-.6-10.8-1.9-15.8 31.3-16 19.8-62.5-14.9-62.5zM302.8 331c-18.2 18.2-76.1 17.9-93.6 0-2.2-2.2-6.1-2.2-8.3 0-2.5 2.5-2.5 6.4 0 8.6 22.8 22.8 87.3 22.8 110.2 0 2.5-2.2 2.5-6.1 0-8.6-2.2-2.2-6.1-2.2-8.3 0zm7.7-75c-13.6 0-24.6 11.1-24.6 24.9 0 13.6 11.1 24.6 24.6 24.6 13.8 0 24.9-11.1 24.9-24.6 0-13.8-11-24.9-24.9-24.9z"/></svg>`;
const iconPlay = `<svg viewBox="0 0 24 24" class="w-4.5 h-4.5" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.25 1.5C3.04 1.71 2.92 2.05 2.92 2.47V21.53C2.92 21.95 3.04 22.29 3.25 22.5L3.33 22.58L13.88 12.03V11.97L3.33 1.42L3.25 1.5Z" fill="#00A0FF"/><path d="M17.38 15.53L13.88 12.03V11.97L17.38 8.47L17.46 8.52L21.66 10.91C22.86 11.59 22.86 12.41 21.66 13.09L17.46 15.48L17.38 15.53Z" fill="#FFBB00"/><path d="M17.46 8.52L13.88 12.03L3.33 22.58C3.67 22.94 4.25 22.98 4.93 22.59L17.46 15.48L17.46 8.52Z" fill="#FF3A44"/><path d="M17.46 8.52L4.93 1.41C4.25 1.02 3.67 1.06 3.33 1.42L13.88 11.97L17.46 8.52Z" fill="#00E676"/></svg>`;

// MOCK DATA for rich SaaS features
const mockEvidence = [
  { source: 'Google Play', text: "The app keeps freezing after the latest update. Very slow and unresponsive.", time: '10 mins ago', icon: iconPlay },
  { source: 'Reddit', text: "Facing timeout and low performance since yesterday. Seems related to the new release.", time: '12 mins ago', icon: iconReddit },
  { source: 'Twitter', text: "@yourapp experiencing major slowdowns. Requests taking too long to process.", time: '15 mins ago', icon: iconX }
];

const mockSources = [
  { name: 'Google Play', count: 182, icon: iconPlay },
  { name: 'Reddit', count: 41, icon: iconReddit },
  { name: 'Twitter', count: 23, icon: iconX },
  { name: 'App Store', count: 18, icon: iconApple }
];

const mockTimeline: Array<{ time: string, event: string, details?: string }> = [
  { time: '12:23 PM', event: 'Alert triggered - Trace value dropped below threshold' },
  { time: '12:21 PM', event: 'Trace value: 45 (threshold: 70)' },
  { time: '12:15 PM', event: 'Anomaly detected in trace pattern' },
  { time: '12:10 PM', event: 'Trace value: 65' }
];

---

<DashboardLayout title="Alerts">
  <div class="max-w-[1600px] mx-auto w-full">
    
    <!-- PAGE HEADER -->
    <div class="flex flex-col gap-6 mb-10 mt-2">
      <!-- Top nav row -->
      <div class="flex items-center justify-between">
        <a href="/dashboard/alerts" class="inline-flex items-center gap-1.5 text-[13px] font-medium text-text-muted hover:text-text-primary transition-colors outline-none w-max">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to alerts
        </a>
        <div class="text-[13px] font-medium text-text-muted">
          Jun 17, 2026, 12:33 PM
        </div>
      </div>
        
      <!-- Title & Badges -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <span class="px-2 py-1 bg-[#A32D2D]/10 text-[#A32D2D] rounded text-[11px] font-bold uppercase tracking-widest">{alert.type === 'critical' ? 'Critical' : alert.type} Alert</span>
          <span class="text-[14px] text-text-secondary font-mono">al_1_124</span>
        </div>
        
        <h1 class="text-[28px] md:text-[32px] font-semibold tracking-tight text-text-primary max-w-4xl leading-[1.2]">
          Trace tr_124 - below threshold 70
        </h1>
        
        <div class="flex items-center gap-2 text-[14px] text-text-secondary font-medium">
          <span>{alert.sub.split('•')[0].trim() || '10 mins ago'}</span>
          <span>•</span>
          <span>Quality Drop</span>
          <span>•</span>
          <span>guest_project</span>
        </div>
      </div>
    </div>

    <!-- MAIN LAYOUT (70 / 30 SPLIT) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
      
      <!-- LEFT COLUMN (Main Content - 70%) -->
      <div class="lg:col-span-8 flex flex-col gap-6">
        
        <!-- SECTION 1: AI Executive Summary -->
        <div class="bg-bg-surface border border-border-default rounded-[20px] p-8 flex flex-col gap-6">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>
            <h2 class="text-[16px] font-semibold text-text-primary">AI Summary</h2>
          </div>
          
          <div class="text-[14px] text-text-primary leading-relaxed max-w-4xl">
            <p>Our intelligence engine detected a significant quality drop. The trace value fell below the expected threshold of 70, indicating potential performance degradation.</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-0 border border-border-faint rounded-xl overflow-hidden bg-bg-subtle/30 mt-2">
            <div class="p-5 flex flex-col gap-3 border-r border-border-faint">
              <span class="text-[12px] text-text-secondary font-medium">What happened</span>
              <div class="flex items-center gap-2">
                <span class="text-[14px] font-medium text-text-primary flex items-center gap-1">Trace value dropped to <RollingNumber client:load value={45} /></span>
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-md bg-[#A32D2D]/10 text-[#A32D2D]"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg></span>
              </div>
              <span class="text-[12px] text-text-muted mt-1">threshold: 70</span>
            </div>
            <div class="p-5 flex flex-col gap-3 border-r border-border-faint">
              <span class="text-[12px] text-text-secondary font-medium">Detected</span>
              <span class="text-[14px] font-medium text-text-primary">10 mins ago</span>
              <span class="text-[12px] text-text-muted mt-1">Jun 17, 12:23 PM</span>
            </div>
            <div class="p-5 flex flex-col gap-3">
              <span class="text-[12px] text-text-secondary font-medium">Confidence</span>
              <span class="text-[14px] font-semibold text-text-primary flex items-center"><RollingNumber client:load value="96%" /></span>
              <span class="text-[12px] text-emerald-600 font-medium mt-1">High confidence</span>
            </div>
          </div>
        </div>

        <!-- Evidence & Sources Row -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
          
          <!-- SECTION 2: Evidence (col-span-3) -->
          <div class="md:col-span-3 bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col">
            <h2 class="text-[14px] font-semibold text-text-primary mb-6">Evidence (5)</h2>
            <div class="flex flex-col gap-6 max-h-[320px] overflow-y-auto pr-2">
              {mockEvidence.map((ev) => (
                <div class="flex items-start gap-4">
                  <div class="mt-0.5 flex-shrink-0" set:html={ev.icon}></div>
                  <div class="flex flex-col gap-1 w-full">
                    <div class="flex items-center justify-between">
                      <span class="text-[13px] font-semibold text-text-primary">{ev.source} {ev.source === 'Twitter' ? 'Mention' : 'Review'}</span>
                      <a href="#" class="text-[11px] text-text-muted hover:text-text-primary flex items-center gap-1 group/link">
                        {ev.time} 
                        <svg class="w-3.5 h-3.5 group-hover/link:-translate-y-0.5 group-hover/link:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                      </a>
                    </div>
                    <p class="text-[13px] text-text-secondary">"{ev.text}"</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- SECTION 3: Affected Sources (col-span-2) -->
          <div class="md:col-span-2 bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col">
            <h2 class="text-[14px] font-semibold text-text-primary mb-6">Sources Affected</h2>
            <div class="flex flex-col gap-5 max-h-[320px] overflow-y-auto pr-2">
              {mockSources.map(source => (
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="flex-shrink-0" set:html={source.icon}></div>
                    <span class="text-[13px] font-medium text-text-primary">{source.name}</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="text-[13px] font-medium text-text-primary flex"><RollingNumber client:load value={source.count} /></span>
                    <span class="text-[11px] font-medium text-[#A32D2D] flex items-center gap-0.5 w-max justify-end">
                      &uarr; <RollingNumber client:load value={source.count * 2 + 10 + '%'} />
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>

        <!-- SECTION 4: Recommended Actions -->
        <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
              <h2 class="text-[15px] font-semibold text-text-primary">Recommended Actions</h2>
            </div>
            <span class="px-2.5 py-1 bg-[#A32D2D]/10 text-[#A32D2D] rounded text-[11px] font-semibold tracking-wide">Priority: High</span>
          </div>

          <div class="flex flex-col gap-4 mb-6">
            <div class="flex items-start gap-4">
              <span class="text-[13px] font-mono text-text-secondary mt-0.5">1</span>
              <p class="text-[13px] text-text-primary">Investigate the root cause of the quality drop in trace performance.</p>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-[13px] font-mono text-text-secondary mt-0.5">2</span>
              <p class="text-[13px] text-text-primary">Check recent deployments or configuration changes.</p>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-[13px] font-mono text-text-secondary mt-0.5">3</span>
              <p class="text-[13px] text-text-primary">Monitor the trace value closely and set up additional alerts if needed.</p>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-0 border border-border-faint rounded-xl overflow-hidden bg-bg-subtle/30 mb-6">
            <div class="p-4 flex flex-col gap-1 border-r border-border-faint">
              <span class="text-[11px] text-text-secondary font-medium">Expected Impact</span>
              <span class="text-[14px] font-semibold text-[#A32D2D]">High</span>
            </div>
            <div class="p-4 flex flex-col gap-1 border-r border-border-faint">
              <span class="text-[11px] text-text-secondary font-medium">Effort</span>
              <span class="text-[14px] font-semibold text-amber-500">Medium</span>
            </div>
            <div class="p-4 flex flex-col gap-1">
              <span class="text-[11px] text-text-secondary font-medium">Confidence</span>
              <span class="text-[14px] font-semibold text-emerald-600 flex items-center"><RollingNumber client:load value="96%" /></span>
            </div>
          </div>
        </div>

        <!-- SECTION 5: Timeline -->
        <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-[15px] font-semibold text-text-primary">Timeline</h2>
          </div>
          
          <div class="flex flex-col gap-0 relative max-h-[400px] overflow-y-auto pr-2">
            <AlertTimeline client:load timeline={mockTimeline} />
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN (Sticky Sidebar - 30%) -->
      <div class="lg:col-span-4">
        <div class="sticky top-6 flex flex-col gap-6">
          
          <!-- Card 1: Alert Status -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col gap-5">
            <h2 class="text-[15px] font-semibold text-text-primary">Alert Status</h2>
            <div class="flex flex-col gap-4">
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Severity</span>
                <span class="px-2 py-0.5 bg-[#A32D2D]/10 text-[#A32D2D] rounded text-[11px] font-bold">Critical</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Status</span>
                <span class="px-2 py-0.5 bg-blue-500/10 text-blue-600 rounded text-[11px] font-bold">New</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Impact Score</span>
                <span class="text-[14px] font-bold text-[#A32D2D] flex items-center"><RollingNumber client:load value="45%" /></span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-[13px] text-text-secondary">Confidence</span>
                <span class="px-2 py-0.5 bg-emerald-500/10 text-emerald-600 rounded text-[11px] font-bold flex items-center gap-0.5"><RollingNumber client:load value="96%" /></span>
              </div>
            </div>
          </div>

          <!-- Card 2: Alert Details -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col gap-5">
            <h2 class="text-[15px] font-semibold text-text-primary">Alert Details</h2>
            <div class="flex flex-col gap-3.5">
              <div class="flex justify-between items-start">
                <span class="text-[13px] text-text-secondary mt-0.5">Alert ID</span>
                <span class="text-[13px] text-text-primary font-mono">{alert.id}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">Project</span>
                <span class="text-[13px] text-text-primary">{alert.project_id || 'guest_project'}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">Type</span>
                <span class="text-[13px] text-text-primary">Quality Drop</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">First Detected</span>
                <span class="text-[13px] text-text-primary">{dateStr}</span>
              </div>
              <div class="flex justify-between items-start mt-1">
                <span class="text-[13px] text-text-secondary">Last Updated</span>
                <span class="text-[13px] text-text-primary">Jun 17, 12:33 PM</span>
              </div>

          </div>

          <!-- Card 3: Similar Alerts -->
          <div class="bg-bg-surface border border-border-default rounded-[20px] p-6 flex flex-col gap-4">
            <h2 class="text-[15px] font-semibold text-text-primary">Similar Alerts</h2>
            <div class="flex flex-col gap-4 max-h-[250px] overflow-y-auto pr-2">
              <div class="flex items-center justify-between group cursor-pointer">
                <div class="flex flex-col gap-1">
                  <span class="text-[13px] text-text-primary font-medium group-hover:text-accent transition-colors">Trace tr_120 - below threshold 70</span>
                  <span class="text-[12px] text-text-muted">Quality Drop • 2 days ago</span>
                </div>
                <svg class="w-4 h-4 text-text-muted group-hover:text-text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </div>
              <div class="flex items-center justify-between group cursor-pointer">
                <div class="flex flex-col gap-1">
                  <span class="text-[13px] text-text-primary font-medium group-hover:text-accent transition-colors">Trace tr_098 - below threshold 70</span>
                  <span class="text-[12px] text-text-muted">Quality Drop • 1 week ago</span>
                </div>
                <svg class="w-4 h-4 text-text-muted group-hover:text-text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </div>
              <div class="flex items-center justify-between group cursor-pointer">
                <div class="flex flex-col gap-1">
                  <span class="text-[13px] text-text-primary font-medium group-hover:text-accent transition-colors">Trace tr_075 - below threshold 70</span>
                  <span class="text-[12px] text-text-muted">Quality Drop • 2 weeks ago</span>
                </div>
                <svg class="w-4 h-4 text-text-muted group-hover:text-text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </div>
            </div>
